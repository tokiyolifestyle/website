<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500&display=swap">
  <style>
    :root{
      --color-primary: {{ settings.color_primary | default: '#111111' }};
      --color-secondary: {{ settings.color_secondary | default: '#FFFFFF' }};
      --color-accent: {{ settings.color_accent | default: '#ff0000' }};
      --color-background: {{ settings.color_background | default: '#F9F9F9' }};
    }
    body.password-page{
      min-height:100vh;display:flex;align-items:center;justify-content:center;
      background:var(--color-background);font-family:var(--font-body, 'Inter', sans-serif);
      text-align:center;padding:2rem;
    }
    .password-wrap{max-width:480px;width:100%;}
    .password-wrap img.logo{max-width:180px;margin-bottom:2rem;}
    .password-wrap h1{font-family:'Poppins',sans-serif;font-size:2rem;margin-bottom:1rem;color:var(--color-primary);}
    .password-wrap p{color:#555;margin-bottom:2rem;}
    .password-form{display:flex;gap:.5rem;margin-bottom:1.5rem;}
    .password-form input[type="password"]{flex:1;padding:.85rem 1rem;border:1px solid #ddd;border-radius:8px;font-size:1rem;}
    .password-form button{padding:.85rem 1.5rem;background:var(--color-primary);color:#fff;border:none;border-radius:8px;cursor:pointer;font-weight:600;}
    .password-form button:hover{background:var(--color-accent);}
    .social-links a{margin:0 .5rem;color:var(--color-primary);text-decoration:none;}
  </style>
</head>
<body class="password-page">
  <div class="password-wrap">
    {%- if settings.logo != blank -%}
      <img class="logo" src="{{ settings.logo | image_url: width: 360 }}" alt="{{ shop.name }}" width="180" height="180" loading="eager">
    {%- else -%}
      <h1>{{ shop.name }}</h1>
    {%- endif -%}

    <h1>{{ 'general.password_page.opening_soon' | t | default: "We'll be back soon" }}</h1>
    <p>{{ 'general.password_page.opening_message' | t | default: 'Tokiyo Lifestyle is putting the finishing touches on something special.' }}</p>

    {%- form 'storefront_password' -%}
      <div class="password-form">
        <label for="Password" class="visually-hidden">{{ 'general.password_page.password' | t | default: 'Password' }}</label>
        <input type="password" name="password" id="Password" placeholder="{{ 'general.password_page.password_placeholder' | t | default: 'Enter store password' }}" required>
        <button type="submit">{{ 'general.password_page.enter' | t | default: 'Enter' }}</button>
      </div>
      {%- if form.errors -%}
        <p style="color:var(--color-error, #D72638);">{{ 'general.password_page.login_form_error' | t | default: 'Incorrect password' }}</p>
      {%- endif -%}
    {%- endform -%}

    <div class="social-links">
      {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" aria-label="Instagram">Instagram</a>{%- endif -%}
      {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" aria-label="Facebook">Facebook</a>{%- endif -%}
    </div>
  </div>
  <div style="display: none;">{{ content_for_layout }}</div>
</body>
</html>
