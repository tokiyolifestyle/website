<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap"></noscript>

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'animations.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
  {{ 'component-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-collection.css' | asset_url | stylesheet_tag }}

  <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'wishlist.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  <script>document.documentElement.classList.remove('no-js');document.documentElement.classList.add('js');</script>

  <style>
    :root{
      --color-primary: {{ settings.color_primary | default: '#111111' }};
      --color-secondary: {{ settings.color_secondary | default: '#FFFFFF' }};
      --color-accent: {{ settings.color_accent | default: '#B89047' }};
      --color-background: {{ settings.color_background | default: '#FAFAF9' }};
      --color-success: {{ settings.color_success | default: '#2E7D32' }};
      --color-error: {{ settings.color_error | default: '#C62828' }};
      --color-surface: #FFFFFF;
      --color-surface-raised: #FFFFFF;
      --color-border: rgba(0,0,0,0.08);
      --color-text-muted: #767674;
      --font-heading: {% if settings.type_header_font == 'playfair_display' %}'Playfair Display', serif{% elsif settings.type_header_font == 'outfit' %}'Outfit', sans-serif{% else %}'Poppins', sans-serif{% endif %};
      --font-body: {% if settings.type_body_font == 'plus_jakarta_sans' %}'Plus Jakarta Sans', sans-serif{% else %}'Inter', sans-serif{% endif %};
      --card-radius: {{ settings.card_border_radius | default: 0 }}px;
      --button-radius: {{ settings.button_border_radius | default: 0 }}px;
      --page-width: {{ settings.page_width | default: 1400 }}px;
      --spacing-sections: {{ settings.spacing_sections | default: 64 }}px;
      --grid-gutter: {{ settings.grid_gutter | default: 24 }}px;
    }
  </style>

  {{ settings.custom_css }}
  {% render 'seo' %}
  {%- if template == 'list-collections' -%}
    <script>window.location.href = '/collections/all';</script>
  {%- endif -%}
</head>

<body class="template-{{ request.page_type | handle }}">

  {%- comment -%} Scroll Progress Bar {%- endcomment -%}
  <div data-scroll-progress style="width:0%;"></div>

  <a class="skip-to-content-link visually-hidden" href="#MainContent">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {% sections 'header-group' %}

  <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% section 'cart-drawer' %}
  {% section 'search-drawer' %}
  {% section 'quick-view-modal' %}
  {% section 'popup-newsletter' %}

  <button id="BackToTop" class="back-to-top" aria-label="{{ 'accessibility.back_to_top' | t }}">
    {% render 'icon-arrow-up' %}
  </button>

  <div id="LoadingOverlay" class="loading-overlay" aria-hidden="true">
    <div class="loading-spinner"></div>
  </div>

  <a href="https://wa.me/917788847469" class="whatsapp-widget" target="_blank" rel="noopener" aria-label="Chat with us on WhatsApp">
    <span class="whatsapp-widget__icon">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.424 2.5 1.134 3.471L6.5 20.5l5.228-1.078a5.75 5.75 0 0 0 3.303.498 5.772 5.772 0 0 0 2.768-1.566 5.76 5.76 0 0 0 1.564-2.77 5.774 5.774 0 0 0-.498-3.302l1.078-5.228-5.066.899a5.727 5.727 0 0 0-2.87-.791zm0-1.102c3.791 0 6.866 3.075 6.867 6.867.001 1.837-.716 3.506-1.886 4.738l1.018 4.935-5.067-1.045a6.83 6.83 0 0 1-3.666-.312L4.363 21.3l1.045-5.066a6.828 6.828 0 0 1-.312-3.666l-1.018-4.935 4.935 1.018a6.82 6.82 0 0 1 4.738-1.886z"/>
        <path d="M12.031 7.234c-2.597 0-4.706 2.109-4.707 4.706 0 1.011.32 1.947.863 2.715l-.611 2.96 3.036-.626a4.673 4.673 0 0 0 1.419.222c2.596 0 4.706-2.109 4.707-4.706a4.708 4.708 0 0 0-4.707-4.706zM9.54 9.61c.148 0 .285.006.398.017.118.012.235.032.327.218.118.238.402.973.438 1.045.036.073.06.155.011.25-.048.095-.072.155-.143.238-.07.083-.148.185-.213.25-.072.072-.148.149-.06.3.088.15.39.643.837 1.04.576.512 1.062.671 1.21.743.149.072.235.06.322-.04.088-.1.378-.44.478-.592.1-.15.2-.124.337-.074.137.05.873.411.973.461.1.05.166.075.19.117.024.042.024.24-.05.45-.074.21-.433.411-.607.438-.174.027-.337.062-1.127-.25-.972-.384-1.597-1.371-1.645-1.437-.049-.066-.395-.526-.395-1.002s.25-.71.338-.806c.088-.095.19-.118.25-.118h.142z"/>
      </svg>
    </span>
    <span class="whatsapp-widget__text">Chat on WhatsApp</span>
  </a>

</body>
</html>
