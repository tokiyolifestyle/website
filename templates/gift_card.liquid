<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ 'Gift Card' }} — {{ shop.name }}</title>
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500&display=swap">
  <style>
    :root { --color-primary:#111111;--color-accent:#ff0000;--color-background:#F9F9F9; }
    body { min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--color-background);font-family:'Inter',sans-serif;padding:2rem; }
    .gift-card { max-width:520px;width:100%;text-align:center;background:#fff;border-radius:20px;padding:3rem 2.5rem;box-shadow:0 20px 60px rgba(17,17,17,.1); }
    .gift-card__logo { margin-bottom:1.5rem; }
    .gift-card__logo-text { font-family:'Poppins',sans-serif;font-weight:800;font-size:1.5rem;letter-spacing:.04em; }
    .gift-card__title { font-size:1.5rem;margin-bottom:1rem; }
    .gift-card__balance { font-size:3rem;font-weight:800;color:var(--color-accent,#ff0000);margin:1rem 0; }
    .gift-card__code { background:#f5f5f5;border-radius:12px;padding:1.25rem;margin:1.5rem 0;font-size:1.5rem;font-weight:700;letter-spacing:.2em;font-family:monospace; }
    .gift-card__expires { color:#888;font-size:.875rem;margin-bottom:1.5rem; }
    .gift-card__actions { display:flex;flex-direction:column;gap:.75rem; }
  </style>
</head>
<body>
  <div class="gift-card">
    <div class="gift-card__logo">
      {%- if settings.logo != blank -%}
        {{ settings.logo | image_url: width: 240 | image_tag: alt: shop.name, loading: 'eager' }}
      {%- else -%}
        <span class="gift-card__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </div>
    <h1 class="gift-card__title">Gift Card</h1>
    <p>Here's your gift card worth:</p>
    <p class="gift-card__balance">{{ gift_card.initial_value | money }}</p>
    <div class="gift-card__code">
      {{ gift_card.code | format_code }}
    </div>
    {%- if gift_card.expires_on -%}
      <p class="gift-card__expires">Expires: {{ gift_card.expires_on | date: '%B %d, %Y' }}</p>
    {%- endif -%}
    <p>Remaining balance: <strong>{{ gift_card.balance | money }}</strong></p>
    <div class="gift-card__actions">
      <a href="{{ shop.url }}" class="button button--solid">{{ 'general.continue_shopping' | t }}</a>
      <button onclick="window.print()" class="button button--outline">Print Gift Card</button>
    </div>
  </div>
</body>
</html>
