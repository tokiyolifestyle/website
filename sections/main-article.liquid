<article class="article-page page-width" itemscope itemtype="https://schema.org/Article">
  {% render 'breadcrumbs' %}
  <header class="article-page__header animate-on-scroll fade-up">
    <p class="text-eyebrow">{{ blog.title }}</p>
    <h1 itemprop="headline">{{ article.title }}</h1>
    <div class="article-page__meta">
      <span itemprop="author">{{ article.author }}</span>
      <span>·</span>
      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">{{ article.published_at | date: '%B %d, %Y' }}</time>
    </div>
  </header>
  {%- if article.image -%}
    <div class="article-page__image animate-on-scroll scale-in">
      {{ article.image | image_url: width: 1200 | image_tag: loading: 'eager', fetchpriority: 'high', widths: '750, 1000, 1200', sizes: '(max-width:749px) 100vw, 820px', itemprop: 'image', alt: article.title | escape }}
    </div>
  {%- endif -%}
  <div class="article-page__body rte animate-on-scroll fade-up" itemprop="articleBody">{{ article.content }}</div>
  {%- if article.tags.size > 0 -%}
    <div class="article-page__tags">
      {%- for tag in article.tags -%}<a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-tag">{{ tag }}</a>{%- endfor -%}
    </div>
  {%- endif -%}
  <div class="article-page__nav">
    {%- if blog.previous_article -%}<a href="{{ blog.previous_article }}" class="button button--outline">← Previous</a>{%- endif -%}
    {%- if blog.next_article -%}<a href="{{ blog.next_article }}" class="button button--outline">Next →</a>{%- endif -%}
  </div>
</article>
<style>
  .article-page { padding-block:2.5rem var(--spacing-sections,64px); max-width:820px; }
  .article-page__header { margin-bottom:2rem; text-align:center; }
  .article-page__header h1 { font-size:clamp(1.75rem,3vw,2.75rem); margin-bottom:1rem; }
  .article-page__meta { font-size:.875rem; color:#888; display:flex; gap:.5rem; justify-content:center; }
  .article-page__image { border-radius:var(--card-radius,12px); overflow:hidden; margin-bottom:2.5rem; aspect-ratio:16/9; }
  .article-page__image img { width:100%; height:100%; object-fit:cover; }
  .article-page__body { line-height:1.8; color:#444; }
  .article-page__tags { display:flex; gap:.5rem; flex-wrap:wrap; margin-top:2rem; }
  .article-tag { padding:.3rem .75rem; background:#f0f0f0; border-radius:20px; font-size:.8125rem; }
  .article-tag:hover { background:var(--color-primary,#111); color:#fff; }
  .article-page__nav { display:flex; gap:1rem; justify-content:space-between; margin-top:2.5rem; }
</style>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "image": "{{ article.image | image_url: width: 1200 }}",
  "author": { "@type": "Person", "name": {{ article.author | json }} },
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S' }}",
  "publisher": { "@type": "Organization", "name": {{ shop.name | json }} }
}
</script>
{% schema %}
{ "name": "Article", "tag": "section", "class": "section-article" }
{% endschema %}
