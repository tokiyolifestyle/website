<section class="scrolling-text section-scrolling-text" style="background:{{ section.settings.background }};color:{{ section.settings.text_color }};">
  <div class="marquee-wrap" aria-hidden="true">
    <div class="marquee-track">
      {%- assign items = section.settings.text | split: '|' -%}
      {%- for item in items -%}
        <span class="marquee-item">{{ item | strip }}{% if section.settings.separator != blank %} <span class="marquee-sep">{{ section.settings.separator }}</span> {% endif %}</span>
      {%- endfor -%}
      {%- comment -%}Duplicate for seamless loop{%- endcomment -%}
      {%- for item in items -%}
        <span class="marquee-item">{{ item | strip }}{% if section.settings.separator != blank %} <span class="marquee-sep">{{ section.settings.separator }}</span> {% endif %}</span>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .scrolling-text { overflow:hidden; padding-block:{{ section.settings.padding_vertical }}px; }
  .marquee-item { display:inline-block; white-space:nowrap; font-size:{{ section.settings.font_size }}px; font-weight:{{ section.settings.font_weight }}; padding:0 .5rem; {% if section.settings.uppercase %}text-transform:uppercase;letter-spacing:.08em;{% endif %} }
  .marquee-sep { color:var(--color-accent,#C9A86A); margin:0 .25rem; }
  .marquee-track { animation-duration:{{ section.settings.speed }}s !important; }
</style>

{% schema %}
{
  "name": "Scrolling Text",
  "tag": "section",
  "class": "section-scrolling-text",
  "settings": [
    { "type": "text", "id": "text", "label": "Text (separate items with |)", "default": "Free Shipping Over ₹2999 | New Season Arrivals | Premium Quality | Wear It Your Way | Shop The Edit | Made For You" },
    { "type": "text", "id": "separator", "label": "Separator between items", "default": "★" },
    { "type": "range", "id": "speed", "min": 10, "max": 60, "step": 5, "unit": "s", "label": "Speed", "default": 22 },
    { "type": "range", "id": "font_size", "min": 12, "max": 40, "step": 2, "unit": "px", "label": "Font size", "default": 16 },
    { "type": "select", "id": "font_weight", "label": "Font weight", "options": [{"value":"400","label":"Regular"},{"value":"600","label":"Semibold"},{"value":"700","label":"Bold"},{"value":"800","label":"ExtraBold"}], "default": "600" },
    { "type": "checkbox", "id": "uppercase", "label": "Uppercase", "default": true },
    { "type": "range", "id": "padding_vertical", "min": 8, "max": 40, "step": 4, "unit": "px", "label": "Padding (top/bottom)", "default": 16 },
    { "type": "color", "id": "background", "label": "Background", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" }
  ],
  "presets": [{ "name": "Scrolling Text" }]
}
{% endschema %}
