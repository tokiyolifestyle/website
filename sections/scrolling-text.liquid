<section class="scrolling-text section-scrolling-text" style="background:{{ section.settings.background | default: '#FFFFFF' }};color:{{ section.settings.text_color | default: '#ff0000' }};border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
  <div class="marquee-wrap" aria-hidden="true">
    <div class="marquee-track" style="animation-duration:{{ section.settings.speed | default: 45 }}s;">
      {%- assign items = section.settings.text | split: '|' -%}
      {%- for item in items -%}
        <span class="marquee-item">{{ item | strip }}{% if section.settings.separator != blank %} <span class="marquee-sep">{{ section.settings.separator }}</span> {% endif %}</span>
      {%- endfor -%}
      {%- for item in items -%}
        <span class="marquee-item">{{ item | strip }}{% if section.settings.separator != blank %} <span class="marquee-sep">{{ section.settings.separator }}</span> {% endif %}</span>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .scrolling-text { overflow:hidden; padding-block:{{ section.settings.padding_vertical | default: 16 }}px; }
  .marquee-item {
    display:inline-block; white-space:nowrap;
    font-size:{{ section.settings.font_size | default: 14 }}px;
    font-weight:{{ section.settings.font_weight | default: '600' }};
    padding:0 1.5rem;
    {% if section.settings.uppercase %}text-transform:uppercase;letter-spacing:.15em;{% endif %}
  }
  .marquee-sep { color:var(--color-accent, #ff0000); margin:0 .5rem; opacity:0.8; }
  @media (max-width: 749px) {
    .scrolling-text {
      padding-block: 8px !important;
    }
    .marquee-item {
      font-size: 11px !important;
      padding: 0 0.75rem !important;
    }
  }
</style>

{% schema %}
{
  "name": "Scrolling Text",
  "tag": "section",
  "class": "section-scrolling-text",
  "settings": [
    { "type": "text", "id": "text", "label": "Text (separate items with |)", "default": "Premium Quality | New Season Arrivals | Free Shipping on Prepaid Orders | Wear Your Confidence | Limited Edition Drops | Crafted With Care" },
    { "type": "text", "id": "separator", "label": "Separator between items", "default": "✦" },
    { "type": "range", "id": "speed", "min": 10, "max": 90, "step": 5, "unit": "s", "label": "Speed", "default": 45 },
    { "type": "range", "id": "font_size", "min": 10, "max": 40, "step": 2, "unit": "px", "label": "Font size", "default": 14 },
    { "type": "select", "id": "font_weight", "label": "Font weight", "options": [{"value":"400","label":"Regular"},{"value":"600","label":"Semibold"},{"value":"700","label":"Bold"},{"value":"800","label":"ExtraBold"}], "default": "600" },
    { "type": "checkbox", "id": "uppercase", "label": "Uppercase", "default": true },
    { "type": "range", "id": "padding_vertical", "min": 8, "max": 40, "step": 4, "unit": "px", "label": "Padding (top/bottom)", "default": 16 },
    { "type": "color", "id": "background", "label": "Background", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ff0000" }
  ],
  "presets": [{ "name": "Scrolling Text" }]
}
{% endschema %}
