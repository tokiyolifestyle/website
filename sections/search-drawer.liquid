<div class="search-drawer-overlay overlay" data-search-overlay></div>
<div class="search-drawer" data-search-drawer id="SearchDrawer" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-drawer__header">
    <h2 class="search-drawer__title">Search</h2>
    <button class="search-drawer__close" data-search-close aria-label="Close">{% render 'icon-close' %}</button>
  </div>
  <div class="search-drawer__form-wrap">
    <form action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <div class="search-drawer__input-wrap">
        <span class="search-drawer__icon">{% render 'icon-search' %}</span>
        <input type="search" name="q" id="SearchDrawerInput" class="search-drawer__input" data-search-input placeholder="{{ 'general.search.placeholder' | t }}" aria-label="Search" autocomplete="off">
        <button type="submit" class="search-drawer__submit" aria-label="Search">{% render 'icon-chevron-right' %}</button>
      </div>
    </form>
  </div>
  {%- if settings.search_show_suggestions -%}
    <div class="search-drawer__suggestions">
      <p class="search-drawer__suggestions-label">Popular searches</p>
      <div class="search-drawer__tags">
        {%- assign suggestions = settings.search_suggestions | split: ',' -%}
        {%- for suggestion in suggestions -%}
          <a href="{{ routes.search_url }}?type=product&q={{ suggestion | strip | url_encode }}" class="search-drawer__tag">{{ suggestion | strip }}</a>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
  <div class="search-drawer__results" data-search-results></div>
</div>
<style>
  .search-drawer { position:fixed;top:0;right:0;height:100%;width:min(480px,100vw);background:#fff;z-index:100000 !important;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;overflow-y:auto; }
  .search-drawer.is-open { transform:translateX(0); }
  .search-drawer-overlay { position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:99999 !important;opacity:0;visibility:hidden;transition:opacity .3s ease,visibility .3s ease; }
  .search-drawer-overlay.is-open { opacity:1;visibility:visible; }
  .search-drawer__header { display:flex;justify-content:space-between;align-items:center;padding:1.25rem 1.5rem;border-bottom:1px solid #f0f0f0; }
  .search-drawer__close { width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center; }
  .search-drawer__close:hover { background:#f5f5f5; }
  .search-drawer__form-wrap { padding:1.5rem; }
  .search-drawer__input-wrap { display:flex;align-items:center;border:2px solid #e5e5e5;border-radius:var(--button-radius,8px);overflow:hidden;transition:border-color .2s; }
  .search-drawer__input-wrap:focus-within { border-color:var(--color-primary,#111); }
  .search-drawer__icon { padding:.75rem;color:#999; }
  .search-drawer__input { flex:1;border:none;outline:none;font-size:1rem;padding:.75rem 0;background:transparent; }
  .search-drawer__submit { padding:.75rem 1rem;background:var(--color-primary,#111);color:#fff;border:none;cursor:pointer; }
  .search-drawer__suggestions { padding:0 1.5rem 1.5rem; }
  .search-drawer__suggestions-label { font-size:.8125rem;color:#888;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.75rem; }
  .search-drawer__tags { display:flex;flex-wrap:wrap;gap:.5rem; }
  .search-drawer__tag { padding:.4rem .85rem;background:#f5f5f5;border-radius:20px;font-size:.8125rem;transition:background .2s,color .2s; }
  .search-drawer__tag:hover { background:var(--color-primary,#111);color:#fff; }
  .search-drawer__results { padding:0 1.5rem 1.5rem; }
  .search-result-item { display:flex;gap:1rem;padding:.75rem 0;border-bottom:1px solid #f5f5f5;align-items:center; }
  .search-result-item__image { width:56px;height:56px;border-radius:8px;overflow:hidden;flex-shrink:0;background:#eee; }
  .search-result-item__image img { width:100%;height:100%;object-fit:cover; }
  .search-result-item__title { font-size:.9rem;font-weight:500;margin-bottom:.2rem; }
  .search-result-item__price { font-size:.8rem;color:#888; }
  .search-drawer__no-results { text-align:center;color:#888;padding:2rem 0; }
</style>
{% schema %}
{
  "name": "Search Drawer",
  "tag": "div",
  "class": "section-search-drawer"
}
{% endschema %}
