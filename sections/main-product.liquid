{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}

<div class="product-page" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="{{ product.title | escape }}">
  <meta itemprop="sku" content="{{ current_variant.sku }}">
  <meta itemprop="brand" content="{{ product.vendor | escape }}">

  {%- comment -%} Breadcrumbs {%- endcomment -%}
  {% render 'breadcrumbs' %}

  <div class="product-page__grid page-width">

    {%- comment -%}====== LEFT: Gallery ======{%- endcomment -%}
    <div class="product-gallery" data-product-gallery>
      <div class="product-gallery__main">
        {%- if product.featured_media -%}
          <div class="product-gallery__main-image">
            {{ product.featured_media | image_url: width: 1000 | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              widths: '500, 750, 1000',
              sizes: '(max-width:749px) 100vw, 50vw',
              id: 'GalleryMainImage',
              data-gallery-main-img: '',
              alt: product.featured_media.alt | default: product.title | escape
            }}
            {%- if settings.enable_image_zoom -%}
              <button class="product-gallery__zoom-btn" data-zoom-toggle aria-label="Zoom image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              </button>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="product-gallery__main-image">{{ 'product-apparel-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs" data-gallery-thumbs>
          {%- for image in product.images limit: 8 -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              data-thumb="{{ image | image_url: width: 1000 }}"
              aria-label="View image {{ forloop.index }}">
              {{ image | image_url: width: 160 | image_tag:
                loading: 'lazy',
                widths: '80, 160',
                alt: image.alt | default: product.title | escape
              }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if settings.enable_image_zoom -%}
        <div class="product-gallery__zoom-modal" data-zoom-modal aria-hidden="true">
          <button class="product-gallery__zoom-close" aria-label="Close zoom">{% render 'icon-close' %}</button>
          <div class="product-gallery__zoom-image" data-zoom-image>
            {{ product.featured_media | image_url: width: 2000 | image_tag: loading: 'lazy', alt: product.title | escape }}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%}====== RIGHT: Product Info ======{%- endcomment -%}
    <div class="product-info" data-sticky-sentinel>
      {%- if product.vendor != blank -%}
        <p class="product-info__vendor text-eyebrow">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 class="product-info__title" itemprop="name">{{ product.title }}</h1>

      {%- comment -%} Price {%- endcomment -%}
      <div class="product-info__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
        <meta itemprop="price" content="{{ current_variant.price | divided_by: 100.0 }}">
        <meta itemprop="availability" content="{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}">
        <span class="product-info__price-current{% if current_variant.compare_at_price > current_variant.price %} price--sale{% endif %}" data-product-price>
          {{ current_variant.price | money }}
        </span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="product-info__price-compare" data-product-compare-price>{{ current_variant.compare_at_price | money }}</span>
          {%- assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="badge badge--sale">{{ 'sections.product.save_amount' | t: amount: save_pct | append: '%' }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Stock Indicator {%- endcomment -%}
      {%- if settings.show_stock_indicator -%}
        <div class="stock-indicator" data-stock-indicator>
          {%- if current_variant.available -%}
            {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity <= settings.low_stock_threshold -%}
              <span class="stock-indicator--low">⚠ Only {{ current_variant.inventory_quantity }} left in stock</span>
            {%- else -%}
              <span class="stock-indicator--in">✓ In Stock</span>
            {%- endif -%}
          {%- else -%}
            <span class="stock-indicator--out">✕ Out of Stock</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Variant Picker {%- endcomment -%}
      <div class="product-variants" data-variant-picker>
        <script data-variant-json type="application/json">{{ product.variants | json }}</script>

        {%- for option in product.options_with_values -%}
          <div class="product-option">
            <div class="product-option__label">
              <span>{{ option.name }}</span>
              {%- if option.name == 'Size' and settings.enable_size_guide -%}
                <button class="product-option__size-guide" data-accordion-trigger aria-expanded="false" aria-controls="SizeGuidePanel" type="button">Size Guide</button>
              {%- endif -%}
            </div>

            {%- if option.name == 'Color' and settings.enable_color_swatches -%}
              <div class="product-option__swatches" role="group" aria-label="Select {{ option.name }}">
                {%- for value in option.values -%}
                  <label class="swatch-label" title="{{ value }}">
                    <input
                      type="radio"
                      name="{{ option.name }}"
                      value="{{ value }}"
                      data-option-name="{{ option.name }}"
                      class="visually-hidden"
                      {% if option.selected_value == value %}checked{% endif %}>
                    <span class="swatch swatch--lg" style="background-color:{{ value | handle | replace: '-', '' }};"></span>
                    <span class="visually-hidden">{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="product-option__buttons" role="group" aria-label="Select {{ option.name }}">
                {%- for value in option.values -%}
                  <label class="option-btn-label">
                    <input
                      type="radio"
                      name="{{ option.name }}"
                      value="{{ value }}"
                      data-option-name="{{ option.name }}"
                      class="visually-hidden"
                      {% if option.selected_value == value %}checked{% endif %}>
                    <span class="option-btn">{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}

        {%- if settings.enable_size_guide -%}
          <div id="SizeGuidePanel" class="size-guide-panel" hidden>
            {% render 'size-guide' %}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Add to cart form {%- endcomment -%}
      {%- form 'product', product, id: product_form_id, data-add-to-cart-form: '' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        <div class="product-info__actions">
          <div class="product-info__qty" data-qty-selector>
            <button type="button" data-qty-dec aria-label="Decrease quantity">{% render 'icon-minus' %}</button>
            <input type="number" name="quantity" id="Qty" data-qty-value value="1" min="1" aria-label="Quantity">
            <button type="button" data-qty-inc aria-label="Increase quantity">{% render 'icon-plus' %}</button>
          </div>

          <button
            type="submit"
            class="button button--solid button--full"
            data-add-to-cart-btn
            data-add-text="{{ 'sections.product.add_to_cart' | t }}"
            {% unless current_variant.available %}disabled{% endunless %}>
            {%- if current_variant.available -%}
              {{ 'sections.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'sections.product.sold_out' | t }}
            {%- endif -%}
          </button>
        </div>

        <a href="{{ routes.checkout_url }}" class="button button--outline button--full product-info__buy-now" onclick="document.getElementById('{{ product_form_id }}').submit(); return false;">
          {{ 'sections.product.buy_now' | t }}
        </a>
      {%- endform -%}

      {%- comment -%} Wishlist + Share {%- endcomment -%}
      <div class="product-info__meta-actions">
        {%- if settings.enable_wishlist -%}
          <button class="product-info__wishlist-btn" data-wishlist-toggle="{{ product.id }}" type="button">
            {% render 'icon-heart' %} <span>{{ 'sections.product.wishlist_add' | t }}</span>
          </button>
        {%- endif -%}
        <button class="product-info__share-btn" data-share-btn type="button">
          {% render 'icon-share' %} <span>{{ 'sections.product.share' | t }}</span>
        </button>
      </div>

      {%- comment -%} Trust badges {%- endcomment -%}
      <div class="product-trust-badges">
        {%- if settings.show_cod_badge -%}
          <div class="trust-badge">{% render 'icon-cash' %}<span>Cash on Delivery</span></div>
        {%- endif -%}
        <div class="trust-badge">{% render 'icon-truck' %}<span>Free delivery above ₹2999</span></div>
        <div class="trust-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Easy 7-day returns</span>
        </div>
      </div>

      {%- comment -%} Delivery Checker {%- endcomment -%}
      {%- if settings.show_delivery_checker -%}
        <div class="delivery-checker">
          <h4>Check Delivery</h4>
          <form class="delivery-checker__form" data-delivery-check-form>
            <div class="delivery-checker__input-wrap">
              <input
                type="text"
                placeholder="Enter 6-digit pincode"
                data-pincode-input
                maxlength="6"
                pattern="[0-9]{6}"
                aria-label="Pincode">
              <button type="submit" class="button button--small button--solid">Check</button>
            </div>
          </form>
          <p class="delivery-result" data-delivery-result></p>
        </div>
      {%- endif -%}

      {%- comment -%} Accordions {%- endcomment -%}
      <div class="product-accordions">
        {%- if product.description != blank -%}
          <div class="accordion" data-accordion>
            <button class="accordion__trigger" data-accordion-trigger data-accordion-group="product" aria-expanded="true" aria-controls="AccordionDesc">
              {{ 'sections.product.description' | t }}
              {% render 'icon-chevron-down' %}
            </button>
            <div class="accordion__panel" id="AccordionDesc">
              <div class="rte product-description">{{ product.description }}</div>
            </div>
          </div>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <div class="accordion" data-accordion {{ block.shopify_attributes }}>
              <button class="accordion__trigger" data-accordion-trigger data-accordion-group="product" aria-expanded="false" aria-controls="Accordion-{{ block.id }}">
                {{ block.settings.title }}
                {% render 'icon-chevron-down' %}
              </button>
              <div class="accordion__panel" id="Accordion-{{ block.id }}" hidden>
                <div class="rte">{{ block.settings.content }}</div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} Sticky Add to Cart {%- endcomment -%}
  {%- if settings.enable_sticky_add_to_cart -%}
    <div class="sticky-atc" data-sticky-atc aria-hidden="true">
      <div class="page-width sticky-atc__inner">
        <div class="sticky-atc__product">
          {%- if product.featured_media -%}
            {{ product.featured_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: product.title | escape, class: 'sticky-atc__img' }}
          {%- endif -%}
          <div>
            <p class="sticky-atc__title">{{ product.title }}</p>
            <p class="sticky-atc__price">{{ current_variant.price | money }}</p>
          </div>
        </div>
        <button
          class="button button--solid"
          type="button"
          onclick="document.getElementById('{{ product_form_id }}').querySelector('[type=submit]').click()">
          {{ 'sections.product.add_to_cart' | t }}
        </button>
      </div>
    </div>
  {%- endif -%}
</div>

{%- comment -%} Related Products {%- endcomment -%}
{%- if section.settings.show_related -%}
  <div class="related-products page-width" style="padding-block:var(--spacing-sections,64px)">
    <div class="section-header-block">
      <h2>{{ 'sections.product.related_products' | t }}</h2>
    </div>
    <div class="product-grid product-grid--4 stagger-children">
      {%- assign related_collections = product.collections -%}
      {%- assign related_count = 0 -%}
      {%- for coll in related_collections limit: 1 -%}
        {%- for related_product in coll.products limit: 5 -%}
          {%- unless related_product.id == product.id -%}
            {%- if related_count < 4 -%}
              {% render 'product-card', product: related_product, lazy: true %}
              {%- assign related_count = related_count | plus: 1 -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<style>
  .product-page__grid { display:grid; grid-template-columns:1fr 1fr; gap:4rem; padding-block:2.5rem; align-items:start; }
  @media(max-width:989px){ .product-page__grid { grid-template-columns:1fr; gap:2rem; } }

  /* Gallery */
  .product-gallery__main-image { position:relative; border-radius:var(--card-radius,12px); overflow:hidden; aspect-ratio:3/4; background:#f5f5f5; }
  .product-gallery__main-image img { width:100%; height:100%; object-fit:cover; }
  .product-gallery__zoom-btn { position:absolute; bottom:12px; right:12px; width:38px; height:38px; border-radius:50%; background:rgba(255,255,255,.9); display:flex; align-items:center; justify-content:center; }
  .product-gallery__thumbs { display:flex; gap:.5rem; margin-top:.75rem; overflow-x:auto; scrollbar-width:none; }
  .product-gallery__thumbs::-webkit-scrollbar { display:none; }
  .product-gallery__thumb { width:70px; height:90px; border-radius:8px; overflow:hidden; border:2px solid transparent; flex-shrink:0; cursor:pointer; transition:border-color .2s; }
  .product-gallery__thumb.is-active { border-color:var(--color-primary,#111); }
  .product-gallery__thumb img { width:100%; height:100%; object-fit:cover; }
  .product-gallery__zoom-modal { position:fixed; inset:0; background:rgba(0,0,0,.92); z-index:100; display:flex; align-items:center; justify-content:center; opacity:0; visibility:hidden; transition:opacity .3s ease,visibility .3s ease; }
  .product-gallery__zoom-modal.is-open { opacity:1; visibility:visible; }
  .product-gallery__zoom-close { position:absolute; top:1.5rem; right:1.5rem; color:#fff; width:40px; height:40px; border-radius:50%; background:rgba(255,255,255,.15); display:flex; align-items:center; justify-content:center; }
  .product-gallery__zoom-image img { max-width:90vw; max-height:90vh; object-fit:contain; }

  /* Info */
  .product-info__vendor { margin-bottom:.35rem; }
  .product-info__title { font-size:clamp(1.5rem,3vw,2.25rem); margin-bottom:1rem; }
  .product-info__price { display:flex; align-items:baseline; gap:.75rem; margin-bottom:.75rem; }
  .product-info__price-current { font-size:1.5rem; font-weight:700; }
  .product-info__price-current.price--sale { color:var(--color-error,#D72638); }
  .product-info__price-compare { font-size:1.1rem; text-decoration:line-through; color:#999; }
  .stock-indicator { font-size:.875rem; margin-bottom:1.25rem; }
  .stock-indicator--in { color:var(--color-success,#3BB273); }
  .stock-indicator--low { color:#F59E0B; }
  .stock-indicator--out { color:var(--color-error,#D72638); }

  /* Variants */
  .product-option { margin-bottom:1.25rem; }
  .product-option__label { display:flex; justify-content:space-between; align-items:center; font-weight:600; font-size:.9rem; margin-bottom:.65rem; }
  .product-option__size-guide { font-size:.8rem; color:var(--color-accent,#C9A86A); text-decoration:underline; }
  .product-option__swatches { display:flex; flex-wrap:wrap; gap:.5rem; }
  .swatch-label input:checked + .swatch { outline:2px solid var(--color-primary,#111); outline-offset:2px; }
  .swatch--lg { width:28px; height:28px; border-radius:50%; cursor:pointer; border:1px solid rgba(0,0,0,.15); display:block; }
  .product-option__buttons { display:flex; flex-wrap:wrap; gap:.5rem; }
  .option-btn-label input:checked + .option-btn { background:var(--color-primary,#111); color:#fff; border-color:var(--color-primary,#111); }
  .option-btn { display:block; padding:.45rem 1rem; border:1.5px solid #ddd; border-radius:6px; font-size:.875rem; cursor:pointer; transition:all .2s; min-width:44px; text-align:center; }
  .option-btn:hover { border-color:var(--color-primary,#111); }
  .size-guide-panel { padding:1.25rem 0; }

  /* Actions */
  .product-info__actions { display:flex; gap:.75rem; margin:1.5rem 0 .75rem; }
  .product-info__qty { display:flex; align-items:center; border:1.5px solid #ddd; border-radius:var(--button-radius,8px); overflow:hidden; flex-shrink:0; }
  .product-info__qty button { width:40px; height:48px; display:flex; align-items:center; justify-content:center; transition:background .2s; }
  .product-info__qty button:hover { background:#f5f5f5; }
  .product-info__qty input { width:48px; text-align:center; border:none; font-size:1rem; font-weight:600; height:48px; }
  .product-info__buy-now { margin-bottom:1rem; }
  .product-info__meta-actions { display:flex; gap:1.25rem; margin-bottom:1.5rem; }
  .product-info__wishlist-btn, .product-info__share-btn { display:flex; align-items:center; gap:.4rem; font-size:.875rem; color:#666; }
  .product-info__wishlist-btn:hover, .product-info__share-btn:hover { color:var(--color-primary,#111); }
  .product-info__wishlist-btn.is-active { color:var(--color-error,#D72638); }

  /* Trust badges */
  .product-trust-badges { display:flex; gap:1rem; flex-wrap:wrap; padding:1rem 0; border-top:1px solid #f0f0f0; border-bottom:1px solid #f0f0f0; margin-bottom:1.25rem; }
  .trust-badge { display:flex; align-items:center; gap:.4rem; font-size:.8125rem; color:#555; }

  /* Delivery checker */
  .delivery-checker { margin-bottom:1.25rem; }
  .delivery-checker h4 { font-size:.9rem; margin-bottom:.65rem; }
  .delivery-checker__input-wrap { display:flex; gap:.5rem; }
  .delivery-checker__input-wrap input { flex:1; padding:.65rem 1rem; border:1.5px solid #ddd; border-radius:8px; font-size:.9rem; }
  .delivery-result { font-size:.8125rem; margin-top:.5rem; }
  .delivery-result--success { color:var(--color-success,#3BB273); }
  .delivery-result--error { color:var(--color-error,#D72638); }

  /* Accordions */
  .product-accordions { border-top:1px solid #f0f0f0; }
  .accordion { border-bottom:1px solid #f0f0f0; }
  .accordion__trigger { display:flex; justify-content:space-between; align-items:center; width:100%; padding:1rem 0; font-weight:600; font-size:.9375rem; text-align:left; }
  .accordion__trigger[aria-expanded="true"] svg { transform:rotate(180deg); }
  .accordion__trigger svg { transition:transform .25s ease; }
  .accordion__panel { padding-bottom:1rem; font-size:.9375rem; line-height:1.7; color:#555; }

  /* Sticky ATC */
  .sticky-atc { position:fixed; bottom:0; left:0; right:0; background:#fff; box-shadow:0 -4px 20px rgba(17,17,17,.1); z-index:30; transform:translateY(100%); transition:transform .3s ease; }
  .sticky-atc.is-visible { transform:translateY(0); }
  .sticky-atc__inner { display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:.9rem 0; }
  .sticky-atc__product { display:flex; gap:.75rem; align-items:center; }
  .sticky-atc__img { width:48px; height:60px; object-fit:cover; border-radius:6px; }
  .sticky-atc__title { font-weight:500; font-size:.9rem; }
  .sticky-atc__price { font-weight:700; font-size:.9rem; }

  /* RTE */
  .rte { line-height:1.7; color:#555; }
  .rte ul { list-style:disc; padding-left:1.25rem; margin:1rem 0; }
  .rte p { margin-bottom:.75rem; }

  /* Breadcrumbs */
  .breadcrumbs { padding:1rem 0; margin-bottom:.5rem; }
  .breadcrumbs ol { display:flex; flex-wrap:wrap; gap:.25rem; list-style:none; font-size:.8125rem; color:#888; }
  .breadcrumbs li:not(:last-child)::after { content:'/'; margin-left:.25rem; }
  .breadcrumbs a:hover { color:var(--color-primary,#111); }
</style>

<script src="{{ 'product-page.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Information",
  "tag": "section",
  "class": "section-product",
  "settings": [
    { "type": "checkbox", "id": "show_related", "label": "Show related products", "default": true }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        { "type": "text", "id": "title", "label": "Accordion title", "default": "Shipping & Returns" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Free shipping on orders over ₹2999. Standard delivery 3–5 business days. Easy 7-day returns on unworn items.</p>" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "accordion", "settings": { "title": "Shipping & Returns", "content": "<p>Free shipping on orders over ₹2999. Standard delivery 3–5 business days. Easy 7-day returns on unworn items with tags attached.</p>" } },
      { "type": "accordion", "settings": { "title": "Care Instructions", "content": "<p>Machine wash cold on gentle cycle. Do not bleach. Tumble dry low. Cool iron if needed.</p>" } },
      { "type": "accordion", "settings": { "title": "About the Brand", "content": "<p>Tokiyo Lifestyle is a premium Indian fashion label committed to quality craftsmanship and sustainable practices.</p>" } }
    ]
  },
  "presets": [{ "name": "Product Information" }]
}
{% endschema %}
