<header class="site-header{% if section.settings.sticky_header %} site-header--sticky{% endif %}" data-site-header>
  <div class="site-header__inner page-width">

    <button class="site-header__mobile-toggle" data-mobile-nav-toggle aria-label="{{ 'sections.header.menu' | t }}" aria-expanded="false" aria-controls="MobileNav">
      {% render 'icon-menu' %}
    </button>

    <div class="site-header__logo">
      <a href="{{ routes.root_url }}" class="site-header__logo-link">
          <img src="{{ 'tokiyo-logo.jpeg' | asset_url }}" 
               loading="eager" 
               alt="{{ shop.name }}" 
               width="{{ settings.logo_width | default: 180 }}" 
               class="header__logo-img">
      </a>
    </div>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list" role="list">
        {%- for link in section.settings.main_menu.links -%}
          <li class="site-header__nav-item{% if link.links.size > 0 %} has-dropdown{% endif %}">
            <a href="{{ link.url }}" class="site-header__nav-link{% if link.active or link.child_active %} is-active{% endif %}" {% if link.links.size > 0 %}aria-haspopup="true" aria-expanded="false" data-mega-menu-trigger="{{ link.handle }}"{% endif %}>
              {{ link.title }}
              {%- if link.links.size > 0 -%}{% render 'icon-chevron-down' %}{%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              {% render 'mega-menu', link: link %}
            {%- endif -%}
          </li>
        {%- endfor -%}
        
        <li class="site-header__nav-item">
          <a href="/pages/about-us" class="site-header__nav-link{% if request.path == '/pages/about-us' %} is-active{% endif %}">About Us</a>
        </li>
        <li class="site-header__nav-item">
          <a href="/pages/bulk-order" class="site-header__nav-link{% if request.path == '/pages/bulk-order' %} is-active{% endif %}">Bulk Order</a>
        </li>
        <li class="site-header__nav-item">
          <a href="/blogs/news" class="site-header__nav-link{% if request.path contains '/blogs/' %} is-active{% endif %}">Blogs</a>
        </li>
      </ul>
    </nav>

    <div class="site-header__icons">
      {%- if section.settings.enable_search -%}
        <button class="site-header__icon-btn" data-search-drawer-toggle aria-label="{{ 'sections.header.search' | t }}">
          {% render 'icon-search' %}
        </button>
      {%- endif -%}

      <a href="{{ routes.account_url }}" class="site-header__icon-btn hide-mobile" aria-label="{{ 'sections.header.account' | t }}">
        {% render 'icon-account' %}
      </a>

      {%- if settings.enable_wishlist -%}
        <a href="{{ routes.root_url }}pages/wishlist" class="site-header__icon-btn hide-mobile" data-wishlist-link aria-label="{{ 'sections.header.wishlist' | t }}">
          {% render 'icon-heart' %}
          <span class="site-header__icon-count" data-wishlist-count>0</span>
        </a>
      {%- endif -%}

      <button class="site-header__icon-btn" data-cart-drawer-toggle aria-label="{{ 'sections.header.cart' | t }}">
        {% render 'icon-cart' %}
        {%- assign cart_item_count = 0 -%}
        {%- for item in cart.items -%}
          {%- if item.variant_id == 48862017716468 -%}{%- continue -%}{%- endif -%}
          {%- assign cart_item_count = cart_item_count | plus: item.quantity -%}
        {%- endfor -%}
        <span class="site-header__icon-count" data-cart-count>{{ cart_item_count }}</span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav" id="MobileNav" data-mobile-nav aria-hidden="true" style="transform: translateX(-100%); visibility: hidden;">
  <div class="mobile-nav__header">
    <span class="mobile-nav__title">{{ shop.name }}</span>
    <button class="mobile-nav__close" data-mobile-nav-close aria-label="{{ 'accessibility.close' | t }}">
      {% render 'icon-close' %}
    </button>
  </div>
  <ul class="mobile-nav__list" role="list">
    {%- for link in section.settings.main_menu.links -%}
      <li class="mobile-nav__item">
        <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
        {%- if link.links.size > 0 -%}
          <button class="mobile-nav__expand" aria-label="Expand {{ link.title }}" data-mobile-submenu-toggle>
            {% render 'icon-chevron-down' %}
          </button>
          <ul class="mobile-nav__sublist" role="list">
            {%- for child_link in link.links -%}
              <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </li>
    {%- endfor -%}
    
    <li class="mobile-nav__item">
      <a href="/pages/about-us" class="mobile-nav__link">About Us</a>
    </li>
    <li class="mobile-nav__item">
      <a href="/pages/bulk-order" class="mobile-nav__link">Bulk Order</a>
    </li>
    <li class="mobile-nav__item">
      <a href="/blogs/news" class="mobile-nav__link">Blogs</a>
    </li>
    <li class="mobile-nav__item">
      <a href="{{ routes.account_url }}" class="mobile-nav__link">My Account</a>
    </li>
    {%- if settings.enable_wishlist -%}
      <li class="mobile-nav__item">
        <a href="{{ routes.root_url }}pages/wishlist" class="mobile-nav__link">My Wishlist</a>
      </li>
    {%- endif -%}
  </ul>
</div>
<div class="mobile-nav__overlay" data-mobile-nav-overlay></div>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_search",
      "label": "Enable search icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Mega Menu Feature Image"
    },
    {
      "type": "image_picker",
      "id": "mega_menu_image",
      "label": "Feature image"
    },
    {
      "type": "url",
      "id": "mega_menu_image_link",
      "label": "Feature image link"
    },
    {
      "type": "text",
      "id": "mega_menu_image_caption",
      "label": "Feature image caption",
      "default": "New Season Edit"
    }
  ]
}
{% endschema %}
