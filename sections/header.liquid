<header class="site-header{% if section.settings.sticky_header %} site-header--sticky{% endif %}" data-site-header>
  <div class="site-header__inner page-width">

    <button class="site-header__mobile-toggle" data-mobile-nav-toggle aria-label="{{ 'sections.header.menu' | t }}" aria-expanded="false" aria-controls="MobileNav">
      {% render 'icon-menu' %}
    </button>

    <div class="site-header__logo">
      <a href="{{ routes.root_url }}" class="site-header__logo-link">
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: settings.logo_width | image_tag:
            loading: 'eager',
            alt: shop.name,
            width: settings.logo_width
          }}
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list" role="list">
        {%- for link in section.settings.main_menu.links -%}
          <li class="site-header__nav-item{% if link.links.size > 0 %} has-dropdown{% endif %}">
            <a href="{{ link.url }}" class="site-header__nav-link" {% if link.links.size > 0 %}aria-haspopup="true" aria-expanded="false" data-mega-menu-trigger="{{ link.handle }}"{% endif %}>
              {{ link.title }}
              {%- if link.links.size > 0 -%}{% render 'icon-chevron-down' %}{%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              {% render 'mega-menu', link: link %}
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="site-header__icons">
      {%- if section.settings.enable_search -%}
        <button class="site-header__icon-btn" data-search-drawer-toggle aria-label="{{ 'sections.header.search' | t }}">
          {% render 'icon-search' %}
        </button>
      {%- endif -%}

      <a href="{{ routes.account_url }}" class="site-header__icon-btn" aria-label="{{ 'sections.header.account' | t }}">
        {% render 'icon-account' %}
      </a>

      {%- if settings.enable_wishlist -%}
        <a href="{{ routes.root_url }}pages/wishlist" class="site-header__icon-btn" data-wishlist-link aria-label="{{ 'sections.header.wishlist' | t }}">
          {% render 'icon-heart' %}
          <span class="site-header__icon-count" data-wishlist-count>0</span>
        </a>
      {%- endif -%}

      <button class="site-header__icon-btn" data-cart-drawer-toggle aria-label="{{ 'sections.header.cart' | t }}">
        {% render 'icon-cart' %}
        <span class="site-header__icon-count" data-cart-count>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav" id="MobileNav" data-mobile-nav aria-hidden="true">
  <div class="mobile-nav__header">
    <span class="mobile-nav__title">{{ shop.name }}</span>
    <button class="mobile-nav__close" data-mobile-nav-close aria-label="{{ 'accessibility.close' | t }}">
      {% render 'icon-close' %}
    </button>
  </div>
  <ul class="mobile-nav__list" role="list">
    {%- for link in section.settings.main_menu.links -%}
      <li class="mobile-nav__item">
        <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
        {%- if link.links.size > 0 -%}
          <button class="mobile-nav__expand" aria-label="Expand {{ link.title }}" data-mobile-submenu-toggle>
            {% render 'icon-chevron-down' %}
          </button>
          <ul class="mobile-nav__sublist" role="list">
            {%- for child_link in link.links -%}
              <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</div>
<div class="mobile-nav__overlay" data-mobile-nav-overlay></div>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_search",
      "label": "Enable search icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Mega Menu Feature Image"
    },
    {
      "type": "image_picker",
      "id": "mega_menu_image",
      "label": "Feature image"
    },
    {
      "type": "url",
      "id": "mega_menu_image_link",
      "label": "Feature image link"
    },
    {
      "type": "text",
      "id": "mega_menu_image_caption",
      "label": "Feature image caption",
      "default": "New Season Edit"
    }
  ]
}
{% endschema %}
