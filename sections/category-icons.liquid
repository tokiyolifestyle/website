{%- comment -%}
  Category Grid — Bewakoof / LimeRoad-style tabbed category browser
  Men's & Women's → Oversized / Regular → 6 subcategories each
{%- endcomment -%}

<section class="category-grid-section" id="CategoryGrid">
  <div class="page-width">
    {%- comment -%} Section Header {%- endcomment -%}
    <div class="catg__header animate-on-scroll fade-up">
      <p class="text-eyebrow">{{ section.settings.eyebrow | default: 'Explore' }}</p>
      <h2>{{ section.settings.title | default: 'Shop by Category' }}</h2>
    </div>

    {%- comment -%} Gender Tabs {%- endcomment -%}
    <div class="catg__tabs" role="tablist">
      <button class="catg__tab is-active" role="tab" aria-selected="true" data-catg-tab="men" id="tab-men" aria-controls="panel-men">
        <span class="catg__tab-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="4" r="2.5"/><path d="M8 24V14H6l4-8h4l4 8h-2v10"/></svg>
        </span>
        MEN
      </button>
      <button class="catg__tab" role="tab" aria-selected="false" data-catg-tab="women" id="tab-women" aria-controls="panel-women">
        <span class="catg__tab-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="4" r="2.5"/><path d="M9 24v-8H7l3-6 2-4 2 4 3 6h-2v8"/></svg>
        </span>
        WOMEN
      </button>
    </div>

    {%- comment -%} ========== MEN'S PANEL ========== {%- endcomment -%}
    <div class="catg__panel is-active" id="panel-men" role="tabpanel" aria-labelledby="tab-men" data-catg-panel="men">

      {%- comment -%} Oversized Section {%- endcomment -%}
      <div class="catg__section">
        <button class="catg__section-header" data-catg-accordion aria-expanded="true">
          <div class="catg__section-title">
            <span class="catg__section-badge">OVERSIZED</span>
            <span class="catg__section-subtitle">Premium Oversized Fits</span>
          </div>
          <svg class="catg__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="catg__section-body is-open">
          <div class="catg__card-grid stagger-children">
            {%- for block in section.blocks -%}
              {%- if block.settings.gender == 'men' and block.settings.fit == 'oversized' -%}
                <a href="{{ block.settings.link | default: '/collections/all' }}" class="catg__card" {{ block.shopify_attributes }}>
                  <div class="catg__card-media">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 600 | image_tag:
                        loading: 'lazy',
                        widths: '300, 450, 600',
                        sizes: '(max-width:600px) 45vw, (max-width:989px) 30vw, 20vw',
                        class: 'catg__card-img',
                        alt: block.settings.label | escape
                      }}
                    {%- else -%}
                      <div class="catg__card-placeholder">
                        <span>{{ block.settings.label | slice: 0 }}</span>
                      </div>
                    {%- endif -%}
                    <div class="catg__card-overlay"></div>
                  </div>
                  <div class="catg__card-info">
                    <span class="catg__card-label">{{ block.settings.label }}</span>
                    <span class="catg__card-arrow">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </span>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      {%- comment -%} Regular Section {%- endcomment -%}
      <div class="catg__section">
        <button class="catg__section-header" data-catg-accordion aria-expanded="true">
          <div class="catg__section-title">
            <span class="catg__section-badge">REGULAR</span>
            <span class="catg__section-subtitle">Classic Fit Collection</span>
          </div>
          <svg class="catg__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="catg__section-body is-open">
          <div class="catg__card-grid stagger-children">
            {%- for block in section.blocks -%}
              {%- if block.settings.gender == 'men' and block.settings.fit == 'regular' -%}
                <a href="{{ block.settings.link | default: '/collections/all' }}" class="catg__card" {{ block.shopify_attributes }}>
                  <div class="catg__card-media">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 600 | image_tag:
                        loading: 'lazy',
                        widths: '300, 450, 600',
                        sizes: '(max-width:600px) 45vw, (max-width:989px) 30vw, 20vw',
                        class: 'catg__card-img',
                        alt: block.settings.label | escape
                      }}
                    {%- else -%}
                      <div class="catg__card-placeholder">
                        <span>{{ block.settings.label | slice: 0 }}</span>
                      </div>
                    {%- endif -%}
                    <div class="catg__card-overlay"></div>
                  </div>
                  <div class="catg__card-info">
                    <span class="catg__card-label">{{ block.settings.label }}</span>
                    <span class="catg__card-arrow">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </span>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} ========== WOMEN'S PANEL ========== {%- endcomment -%}
    <div class="catg__panel" id="panel-women" role="tabpanel" aria-labelledby="tab-women" data-catg-panel="women" hidden>

      {%- comment -%} Oversized Section {%- endcomment -%}
      <div class="catg__section">
        <button class="catg__section-header" data-catg-accordion aria-expanded="true">
          <div class="catg__section-title">
            <span class="catg__section-badge">OVERSIZED</span>
            <span class="catg__section-subtitle">Premium Oversized Fits</span>
          </div>
          <svg class="catg__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="catg__section-body is-open">
          <div class="catg__card-grid stagger-children">
            {%- for block in section.blocks -%}
              {%- if block.settings.gender == 'women' and block.settings.fit == 'oversized' -%}
                <a href="{{ block.settings.link | default: '/collections/all' }}" class="catg__card" {{ block.shopify_attributes }}>
                  <div class="catg__card-media">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 600 | image_tag:
                        loading: 'lazy',
                        widths: '300, 450, 600',
                        sizes: '(max-width:600px) 45vw, (max-width:989px) 30vw, 20vw',
                        class: 'catg__card-img',
                        alt: block.settings.label | escape
                      }}
                    {%- else -%}
                      <div class="catg__card-placeholder">
                        <span>{{ block.settings.label | slice: 0 }}</span>
                      </div>
                    {%- endif -%}
                    <div class="catg__card-overlay"></div>
                  </div>
                  <div class="catg__card-info">
                    <span class="catg__card-label">{{ block.settings.label }}</span>
                    <span class="catg__card-arrow">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </span>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      {%- comment -%} Regular Section {%- endcomment -%}
      <div class="catg__section">
        <button class="catg__section-header" data-catg-accordion aria-expanded="true">
          <div class="catg__section-title">
            <span class="catg__section-badge">REGULAR</span>
            <span class="catg__section-subtitle">Classic Fit Collection</span>
          </div>
          <svg class="catg__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="catg__section-body is-open">
          <div class="catg__card-grid stagger-children">
            {%- for block in section.blocks -%}
              {%- if block.settings.gender == 'women' and block.settings.fit == 'regular' -%}
                <a href="{{ block.settings.link | default: '/collections/all' }}" class="catg__card" {{ block.shopify_attributes }}>
                  <div class="catg__card-media">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 600 | image_tag:
                        loading: 'lazy',
                        widths: '300, 450, 600',
                        sizes: '(max-width:600px) 45vw, (max-width:989px) 30vw, 20vw',
                        class: 'catg__card-img',
                        alt: block.settings.label | escape
                      }}
                    {%- else -%}
                      <div class="catg__card-placeholder">
                        <span>{{ block.settings.label | slice: 0 }}</span>
                      </div>
                    {%- endif -%}
                    <div class="catg__card-overlay"></div>
                  </div>
                  <div class="catg__card-info">
                    <span class="catg__card-label">{{ block.settings.label }}</span>
                    <span class="catg__card-arrow">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </span>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ========== Category Grid Section ========== */
  .category-grid-section {
    padding: var(--spacing-sections, 48px) 0;
    background: #FFFFFF;
  }
  .catg__header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .catg__header h2 {
    margin-bottom: 0.25rem;
  }

  /* ---- Tabs ---- */
  .catg__tabs {
    display: flex;
    justify-content: center;
    gap: 0;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid rgba(0,0,0,0.06);
    position: relative;
  }
  .catg__tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2.5rem;
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted, #767674);
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    position: relative;
  }
  .catg__tab::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--color-accent, #C5A880);
    transform: scaleX(0);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .catg__tab.is-active {
    color: var(--color-primary, #0C0C0E);
  }
  .catg__tab.is-active::after {
    transform: scaleX(1);
  }
  .catg__tab:hover {
    color: var(--color-primary, #0C0C0E);
  }
  .catg__tab-icon {
    display: flex;
    transition: transform 0.3s ease;
  }
  .catg__tab:hover .catg__tab-icon {
    transform: scale(1.15);
  }

  /* ---- Panels ---- */
  .catg__panel {
    display: none;
    animation: catgPanelIn 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  .catg__panel.is-active {
    display: block;
  }
  @keyframes catgPanelIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---- Section Accordion ---- */
  .catg__section {
    margin-bottom: 2rem;
  }
  .catg__section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 1.25rem 0;
    border: none;
    background: none;
    cursor: pointer;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .catg__section-title {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .catg__section-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: var(--color-primary, #0C0C0E);
    color: #FFFFFF;
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .catg__section-subtitle {
    font-size: 0.8125rem;
    color: var(--color-text-muted, #767674);
    font-weight: 500;
  }
  .catg__chevron {
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    color: var(--color-text-muted, #767674);
  }
  .catg__section-header[aria-expanded="false"] .catg__chevron {
    transform: rotate(-90deg);
  }

  /* ---- Section Body ---- */
  .catg__section-body {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.4s ease, padding 0.4s ease;
    padding: 0;
  }
  .catg__section-body.is-open {
    max-height: 1200px;
    opacity: 1;
    padding: 1.5rem 0;
  }

  /* ---- Card Grid ---- */
  .catg__card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media(max-width: 600px) {
    .catg__card-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }

  /* ---- Category Card ---- */
  .catg__card {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 4 / 5;
    background: #F5F5F5;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .catg__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(12, 12, 14, 0.1);
  }

  /* Card Media */
  .catg__card-media {
    position: absolute;
    inset: 0;
  }
  .catg__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .catg__card:hover .catg__card-img {
    transform: scale(1.08);
  }
  .catg__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.2) 40%,
      rgba(0,0,0,0.05) 70%,
      transparent 100%
    );
    transition: background 0.4s ease;
  }
  .catg__card:hover .catg__card-overlay {
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.85) 0%,
      rgba(0,0,0,0.35) 45%,
      rgba(0,0,0,0.1) 75%,
      transparent 100%
    );
  }

  /* Card Placeholder (when no image) */
  .catg__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #F0EFED 0%, #E8E6E3 100%);
    position: relative;
  }
  .catg__card-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,0,0,0.015) 10px, rgba(0,0,0,0.015) 20px);
  }
  .catg__card-placeholder span {
    font-size: 3rem;
    font-weight: 900;
    color: var(--color-accent, #C5A880);
    opacity: 0.2;
    font-family: var(--font-heading);
  }

  /* Card Info */
  .catg__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 2;
  }
  .catg__card-label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #FFFFFF;
    line-height: 1.2;
  }
  .catg__card-arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFFFFF;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }
  .catg__card:hover .catg__card-arrow {
    background: var(--color-accent, #C5A880);
    color: var(--color-primary, #0C0C0E);
    transform: translateX(4px);
  }

  /* ---- Mobile Adjustments ---- */
  @media(max-width: 749px) {
    .catg__tab {
      padding: 0.85rem 1.5rem;
      font-size: 0.75rem;
    }
    .catg__card-label {
      font-size: 0.7rem;
    }
    .catg__card-arrow {
      width: 28px;
      height: 28px;
    }
    .catg__card-info {
      padding: 0.75rem 1rem;
    }
    .catg__section-badge {
      font-size: 0.6rem;
      padding: 0.3rem 0.75rem;
    }
    .catg__section-subtitle {
      font-size: 0.7rem;
    }
  }
</style>

<script>
  (function(){
    /* Tab switching */
    const tabs = document.querySelectorAll('[data-catg-tab]');
    const panels = document.querySelectorAll('[data-catg-panel]');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.catgTab;
        tabs.forEach(t => { t.classList.remove('is-active'); t.setAttribute('aria-selected','false'); });
        panels.forEach(p => { p.classList.remove('is-active'); p.hidden = true; });
        tab.classList.add('is-active');
        tab.setAttribute('aria-selected','true');
        const panel = document.querySelector(`[data-catg-panel="${target}"]`);
        if(panel){ panel.classList.add('is-active'); panel.hidden = false; }
      });
    });
    /* Accordion toggle */
    document.querySelectorAll('[data-catg-accordion]').forEach(btn => {
      btn.addEventListener('click', () => {
        const body = btn.nextElementSibling;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!isOpen));
        body.classList.toggle('is-open', !isOpen);
      });
    });
  })();
</script>

