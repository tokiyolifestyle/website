            {%- endif -%}
            {%- assign black_products = '' -%}
            {%- for p in fallback_collection.products -%}
              {%- assign p_title_lower = p.title | downcase -%}
              {%- if p_title_lower contains 'black' -%}
                {%- assign black_products = black_products | append: p.handle | append: ',' -%}
              {%- endif -%}
            {%- endfor -%}
            {%- assign black_handles = black_products | split: ',' -%}
            {%- assign card_counter = 0 -%}

            {%- for block in section.blocks -%}
              {%- if block.settings.gender == 'men' and block.settings.fit == 'regular' -%}
                {%- assign gender_part = block.settings.gender | downcase -%}
                {%- assign fit_part = block.settings.fit | downcase -%}
                {%- assign label_part = block.settings.label | downcase | replace: ' ', '-' -%}
                {%- if label_part == 'graphic' -%}{%- assign label_part = 'graphic-print' -%}{%- endif -%}
                {%- assign constructed_handle = gender_part | append: '-' | append: fit_part | append: '-' | append: label_part -%}
                
                {%- assign block_link = '/collections/men-regular' -%}
                {%- if block.settings.link != blank -%}{%- assign block_link = block.settings.link -%}{%- endif -%}

                {%- assign card_image = block.settings.image -%}
                {%- if card_image == blank -%}
                  {%- assign current_collection = collections[constructed_handle] -%}
                  {%- if current_collection != blank and current_collection.products.first != blank -%}
                    {%- assign card_image = current_collection.products.first.featured_image -%}
                  {%- else -%}
                    {%- if black_handles.size > 0 -%}
                      {%- assign product_index = card_counter | modulo: black_handles.size -%}
                      {%- assign selected_handle = black_handles[product_index] -%}
                      {%- assign selected_product = all_products[selected_handle] -%}
                      {%- assign card_image = selected_product.featured_image -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
                {%- assign card_counter = card_counter | plus: 1 -%}

                <a href="{{ block_link }}" class="catg-card-3d" data-tilt {{ block.shopify_attributes }}>
                  <div class="catg-card-3d__inner">
                    <div class="catg-card-3d__glow-border"></div>
                    <div class="catg-card-3d__media">
                      {%- if card_image != blank -%}
                        {{ card_image | image_url: width: 600 | image_tag:
                          loading: 'lazy', widths: '300, 450, 600',
                          sizes: '(max-width:600px) 45vw, (max-width:989px) 30vw, 18vw',
                          class: 'catg-card-3d__img', alt: block.settings.label | escape
                        }}
                      {%- else -%}
                        <div class="catg-card-3d__placeholder">
                          <div class="catg-card-3d__placeholder-pattern"></div>
                          <span class="catg-card-3d__placeholder-letter">{{ block.settings.label | slice: 0, 2 }}</span>
                        </div>
                      {%- endif -%}
                      <div class="catg-card-3d__shimmer"></div>
                      <div class="catg-card-3d__overlay"></div>
                    </div>
                    <div class="catg-card-3d__content">
                      <span class="catg-card-3d__tag">REGULAR</span>
                      <h3 class="catg-card-3d__title">{{ block.settings.label }}</h3>
                      <div class="catg-card-3d__explore">
                        <span>Explore</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      </div>
                    </div>
                    <div class="catg-card-3d__shine" data-card-shine></div>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
 
    {%- comment -%} ═══ WOMEN'S PANEL ═══ {%- endcomment -%}
    <div class="catg-universe__panel" data-catg-panel="women" id="upanel-women" hidden>
      {%- comment -%} Oversized {%- endcomment -%}
