{%- comment -%}
  ═══════════════════════════════════════════════════════════════
  TOKIYO CATEGORY UNIVERSE — One-of-a-kind immersive experience
  3D tilt cards, glowing borders, particles, split-reveal, magnetic hover
  ═══════════════════════════════════════════════════════════════
{%- endcomment -%}

<section class="catg-universe" id="CategoryUniverse">
  {%- comment -%} Floating particles background {%- endcomment -%}
  <div class="catg-universe__particles" id="CatgParticles" aria-hidden="true"></div>

  <div class="page-width">
    {%- comment -%} Section Header with animated line {%- endcomment -%}
    <div class="catg-universe__header">
      <p class="text-eyebrow">{{ section.settings.eyebrow | default: 'Explore' }}</p>
      <h2 class="catg-universe__title">
        <span class="catg-universe__title-line" data-split-text>{{ section.settings.title | default: 'Shop by Category' }}</span>
      </h2>
      <div class="catg-universe__title-underline"></div>
    </div>

    {%- comment -%} ═══ Quick Icon Strip (LimeRoad style) ═══ {%- endcomment -%}
    <div class="catg-quickstrip" data-quickstrip>
      <div class="catg-quickstrip__track">
        {%- for block in section.blocks -%}
          {%- if block.settings.show_in_strip -%}
            {%- assign gender_part = block.settings.gender | downcase -%}
            {%- assign fit_part = block.settings.fit | downcase -%}
            {%- assign label_part = block.settings.label | downcase | replace: ' ', '-' -%}
            {%- if label_part == 'graphic' -%}{%- assign label_part = 'graphic-print' -%}{%- endif -%}
            {%- assign constructed_handle = gender_part | append: '-' | append: fit_part | append: '-' | append: label_part -%}
            
            {%- if block.settings.gender == 'men' -%}
              {%- assign block_link = '/collections/men-oversized' -%}
            {%- else -%}
              {%- assign block_link = '/collections/women-oversized' -%}
            {%- endif -%}
            {%- if block.settings.link != blank -%}{%- assign block_link = block.settings.link -%}{%- endif -%}

            {%- assign card_image = block.settings.image -%}
            {%- if card_image == blank -%}
              {%- assign current_collection = collections[constructed_handle] -%}
              {%- if current_collection != blank and current_collection.products.first != blank -%}
                {%- assign card_image = current_collection.products.first.featured_image -%}
              {%- else -%}
                {%- assign fallback_handle = block.settings.gender | append: '-oversized' -%}
                {%- assign fallback_collection = collections[fallback_handle] -%}
                {%- if fallback_collection == blank or fallback_collection.products.size == 0 -%}
                  {%- assign fallback_collection = collections['men-oversized'] -%}
                {%- endif -%}
                {%- if fallback_collection != blank and fallback_collection.products.size > 0 -%}
                  {%- assign img_idx = forloop.index0 | modulo: fallback_collection.products.size -%}
                  {%- assign card_image = fallback_collection.products[img_idx].featured_image -%}
                {%- endif -%}
              {%- endif -%}
            {%- endif -%}

            <a href="{{ block_link }}" class="catg-quickstrip__item" data-quickstrip-item>
              <div class="catg-quickstrip__circle">
                {%- assign strip_img = block.settings.strip_image | default: card_image -%}
                {%- if strip_img != blank -%}
                  {{ strip_img | image_url: width: 120 | image_tag:
                    loading: 'lazy', widths: '60, 120', class: 'catg-quickstrip__img',
                    alt: block.settings.label | escape
                  }}
                {%- else -%}
                  <span class="catg-quickstrip__letter">{{ block.settings.label | slice: 0 }}</span>
                {%- endif -%}
                <div class="catg-quickstrip__glow"></div>
              </div>
              <span class="catg-quickstrip__label">{{ block.settings.label }}</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
 
    {%- comment -%} ═══ Gender Tabs — Futuristic pill style ═══ {%- endcomment -%}
    <div class="catg-universe__tabs" role="tablist">
      <div class="catg-universe__tabs-bg" data-tab-slider></div>
      <button class="catg-universe__tab is-active" role="tab" aria-selected="true" data-catg-tab="men" id="utab-men">
        <span class="catg-universe__tab-text">MEN'S</span>
        <span class="catg-universe__tab-glow"></span>
      </button>
      <button class="catg-universe__tab" role="tab" aria-selected="false" data-catg-tab="women" id="utab-women">
        <span class="catg-universe__tab-text">WOMEN'S</span>
        <span class="catg-universe__tab-glow"></span>
      </button>
    </div>
 
    {%- comment -%} ═══ MEN'S PANEL ═══ {%- endcomment -%}
    <div class="catg-universe__panel is-active" data-catg-panel="men" id="upanel-men">
 
      {%- comment -%} Oversized Section {%- endcomment -%}
      <div class="catg-universe__section">
        <div class="catg-universe__section-header" data-catg-accordion aria-expanded="true">
          <div class="catg-universe__section-left">
            <span class="catg-universe__section-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 8L10 5C10 5 11.5 10 16 10L22 5L20 14H17V22H7V14H4L2 5Z"/></svg>
            </span>
            <div>
              <span class="catg-universe__section-badge">OVERSIZED</span>
              <span class="catg-universe__section-sub">Drop-shoulder premium fits</span>
            </div>
          </div>
          <div class="catg-universe__section-chevron">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>
        <div class="catg-universe__section-body is-open">
          <div class="catg-universe__grid">
            {%- assign fallback_collection = collections['men-oversized'] -%}
            {%- assign black_products = '' -%}
            {%- for p in fallback_collection.products -%}
              {%- assign p_title_lower = p.title | downcase -%}
              {%- if p_title_lower contains 'black' -%}
                {%- assign black_products = black_products | append: p.handle | append: ',' -%}
              {%- endif -%}
            {%- endfor -%}
            {%- assign black_handles = black_products | split: ',' -%}
            {%- assign card_counter = 0 -%}

            {%- for block in section.blocks -%}
              {%- if block.settings.gender == 'men' and block.settings.fit == 'oversized' -%}
                {%- assign gender_part = block.settings.gender | downcase -%}
                {%- assign fit_part = block.settings.fit | downcase -%}
                {%- assign label_part = block.settings.label | downcase | replace: ' ', '-' -%}
                {%- if label_part == 'graphic' -%}{%- assign label_part = 'graphic-print' -%}{%- endif -%}
                {%- assign constructed_handle = gender_part | append: '-' | append: fit_part | append: '-' | append: label_part -%}
                
                {%- assign block_link = '/collections/men-oversized' -%}
                {%- if block.settings.link != blank -%}{%- assign block_link = block.settings.link -%}{%- endif -%}

                {%- assign card_image = block.settings.image -%}
                {%- if card_image == blank -%}
                  {%- assign current_collection = collections[constructed_handle] -%}
                  {%- if current_collection != blank and current_collection.products.first != blank -%}
                    {%- assign card_image = current_collection.products.first.featured_image -%}
                  {%- else -%}
                    {%- if black_handles.size > 0 -%}
                      {%- assign product_index = card_counter | modulo: black_handles.size -%}
                      {%- assign selected_handle = black_handles[product_index] -%}
                      {%- assign selected_product = all_products[selected_handle] -%}
                      {%- assign card_image = selected_product.featured_image -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
                {%- assign card_counter = card_counter | plus: 1 -%}

                <a href="{{ block_link }}" class="catg-card-3d" data-tilt {{ block.shopify_attributes }}>
                  <div class="catg-card-3d__inner">
                    <div class="catg-card-3d__glow-border"></div>
                    <div class="catg-card-3d__media">
                      {%- if card_image != blank -%}
                        {{ card_image | image_url: width: 600 | image_tag:
                          loading: 'lazy', widths: '300, 450, 600',
                          sizes: '(max-width:600px) 45vw, (max-width:989px) 30vw, 18vw',
                          class: 'catg-card-3d__img', alt: block.settings.label | escape
                        }}
                      {%- else -%}
                        <div class="catg-card-3d__placeholder">
                          <div class="catg-card-3d__placeholder-pattern"></div>
                          <span class="catg-card-3d__placeholder-letter">{{ block.settings.label | slice: 0, 2 }}</span>
                        </div>
                      {%- endif -%}
                      <div class="catg-card-3d__shimmer"></div>
                      <div class="catg-card-3d__overlay"></div>
                    </div>
                    <div class="catg-card-3d__content">
                      <span class="catg-card-3d__tag">OVERSIZED</span>
                      <h3 class="catg-card-3d__title">{{ block.settings.label }}</h3>
                      <div class="catg-card-3d__explore">
                        <span>Explore</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      </div>
                    </div>
                    <div class="catg-card-3d__shine" data-card-shine></div>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
 
      {%- comment -%} Regular Section {%- endcomment -%}
      <div class="catg-universe__section">
        <div class="catg-universe__section-header" data-catg-accordion aria-expanded="true">
          <div class="catg-universe__section-left">
            <span class="catg-universe__section-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 8L10 5C10 5 11 9 12 9C13 9 14 5 14 5L18 8L16 14H14V22H10V14H8L6 8Z"/></svg>
            </span>
            <div>
              <span class="catg-universe__section-badge">REGULAR FIT</span>
              <span class="catg-universe__section-sub">Classic comfort essentials</span>
