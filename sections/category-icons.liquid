  @keyframes particleFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(var(--px, 20px), var(--py, -30px)) scale(1.2); }
    50% { transform: translate(var(--px2, -15px), var(--py2, 20px)) scale(0.8); }
    75% { transform: translate(var(--px3, 25px), var(--py3, 10px)) scale(1.1); }
  }

  /* Register CSS custom property for conic-gradient animation */
  @property --glow-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
</style>

{%- comment -%} ═══════════════════ JAVASCRIPT ═══════════════════ {%- endcomment -%}
<script>
(function(){
  'use strict';

  /* ═══ Tab Switching ═══ */
  const tabs = document.querySelectorAll('[data-catg-tab]');
  const panels = document.querySelectorAll('[data-catg-panel]');
  const slider = document.querySelector('[data-tab-slider]');
  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('is-active'); t.setAttribute('aria-selected','false'); });
      panels.forEach(p => { p.classList.remove('is-active'); p.hidden = true; });
      tab.classList.add('is-active');
      tab.setAttribute('aria-selected','true');
      const panel = document.querySelector(`[data-catg-panel="${tab.dataset.catgTab}"]`);
      if(panel) { panel.classList.add('is-active'); panel.hidden = false; }
      /* Slide background pill */
      if(slider) slider.classList.toggle('slide-right', i === 1);
      /* Re-init 3D tilt for new panel */
      init3DTilt();
    });
  });

  /* ═══ Accordion ═══ */
  document.querySelectorAll('[data-catg-accordion]').forEach(btn => {
    btn.addEventListener('click', () => {
      const body = btn.nextElementSibling;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      body.classList.toggle('is-open', !isOpen);
    });
  });

  /* ═══ 3D Tilt Effect ═══ */
  function init3DTilt() {
    if(window.innerWidth < 750 || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    document.querySelectorAll('[data-tilt]').forEach(card => {
      const inner = card.querySelector('.catg-card-3d__inner');
      const shine = card.querySelector('[data-card-shine]');
      if(!inner) return;

      card.addEventListener('mousemove', e => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width;
        const y = (e.clientY - rect.top) / rect.height;
        const tiltX = (0.5 - y) * 20;  /* Max 10 degrees */
        const tiltY = (x - 0.5) * 20;
        inner.style.transform = `rotateX(${tiltX}deg) rotateY(${tiltY}deg) scale(1.02)`;
        /* Move shine spot */
        if(shine) {
          shine.style.setProperty('--shine-x', (x * 100) + '%');
          shine.style.setProperty('--shine-y', (y * 100) + '%');
        }
      });

      card.addEventListener('mouseleave', () => {
        inner.style.transform = '';
        inner.style.transition = 'transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.5s ease';
        setTimeout(() => { inner.style.transition = ''; }, 600);
      });

      card.addEventListener('mouseenter', () => {
        inner.style.transition = 'none';
      });
    });
  }
  init3DTilt();

  /* ═══ Floating Particles ═══ */
  function initParticles() {
    const container = document.getElementById('CatgParticles');
    if(!container || window.innerWidth < 750) return;

    const colors = ['rgba(197,168,128,0.2)', 'rgba(12,12,14,0.06)', 'rgba(197,168,128,0.12)'];
    for(let i = 0; i < 20; i++) {
      const p = document.createElement('div');
      p.className = 'catg-particle';
      const size = 4 + Math.random() * 10;
      p.style.width = size + 'px';
      p.style.height = size + 'px';
      p.style.left = Math.random() * 100 + '%';
      p.style.top = Math.random() * 100 + '%';
      p.style.background = colors[Math.floor(Math.random() * colors.length)];
      p.style.setProperty('--particle-duration', (6 + Math.random() * 8) + 's');
      p.style.setProperty('--particle-opacity', (0.08 + Math.random() * 0.15).toFixed(2));
      p.style.setProperty('--px', (Math.random() * 60 - 30) + 'px');
      p.style.setProperty('--py', (Math.random() * 60 - 30) + 'px');
      p.style.setProperty('--px2', (Math.random() * 60 - 30) + 'px');
      p.style.setProperty('--py2', (Math.random() * 60 - 30) + 'px');
      p.style.setProperty('--px3', (Math.random() * 60 - 30) + 'px');
      p.style.setProperty('--py3', (Math.random() * 60 - 30) + 'px');
      p.style.animationDelay = (Math.random() * 5) + 's';
      container.appendChild(p);
    }
  }
  initParticles();

  /* ═══ Staggered Entrance for Cards ═══ */
  if(window.IntersectionObserver) {
    const gridObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if(entry.isIntersecting) {
          const cards = entry.target.querySelectorAll('.catg-card-3d');
          cards.forEach((card, i) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(30px) scale(0.95)';
            setTimeout(() => {
              card.style.transition = 'opacity 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1)';
              card.style.opacity = '1';
              card.style.transform = 'translateY(0) scale(1)';
            }, 80 * i);
          });
          gridObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.catg-universe__grid').forEach(grid => gridObserver.observe(grid));
  }

})();
</script>

