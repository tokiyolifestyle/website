        <div class="catg-universe__section-header" data-catg-accordion aria-expanded="true">
          <div class="catg-universe__section-left">
            <span class="catg-universe__section-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 8L10 5C10 5 11.5 10 16 10L22 5L20 14H17V22H7V14H4L2 5Z"/></svg>
            </span>
            <div>
              <span class="catg-universe__section-badge">OVERSIZED</span>
              <span class="catg-universe__section-sub">Drop-shoulder premium fits</span>
