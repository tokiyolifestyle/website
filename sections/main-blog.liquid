<div class="blog-page page-width">
  {% render 'breadcrumbs' %}
  
  <div class="blog-header animate-on-scroll fade-up">
    <span class="text-eyebrow">Tokiyo Journal</span>
    <h1>{{ blog.title }}</h1>
    <p>Insights, guides, and stories from the intersection of design, culture, and premium Indian streetwear.</p>
  </div>

  <!-- --- Category tag filters --- -->
  <div class="blog-categories animate-on-scroll fade-up">
    <a href="{{ blog.url }}" class="blog-category-link {% if current_tags == blank %}is-active{% endif %}">All Articles</a>
    {%- assign blog_categories = "Brand & Stories,Fashion & Styling,Fabric & Quality,Care Guides,Buying Guides,Company Updates" | split: "," -%}
    {%- for cat in blog_categories -%}
      {%- assign cat_handle = cat | handle -%}
      {%- assign active_cat = false -%}
      {%- for tag in current_tags -%}
        {%- assign tag_handle = tag | handle -%}
        {%- if tag_handle == cat_handle -%}{%- assign active_cat = true -%}{%- endif -%}
      {%- endfor -%}
      <a href="{{ blog.url }}/tagged/{{ cat_handle }}" class="blog-category-link {% if active_cat %}is-active{% endif %}">{{ cat }}</a>
    {%- endfor -%}
  </div>

  <div class="blog-grid stagger-children">
    {%- if blog.articles.size > 0 -%}
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="article-card hover-lift">
          {%- if article.image -%}
            <div class="article-card__image hover-zoom">
              {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: article.title | escape }}
            </div>
          {%- else -%}
            <div class="article-card__image article-card__image--placeholder hover-zoom">
              <div class="article-card__placeholder-bg"></div>
            </div>
          {%- endif -%}
          <div class="article-card__info">
            <span class="article-card__category">
              {%- if article.tags.size > 0 -%}{{ article.tags | first }}{%- else -%}Tokiyo Journal{%- endif -%}
            </span>
            <p class="article-card__date">{{ article.published_at | date: '%B %d, %Y' }}</p>
            <h2>{{ article.title }}</h2>
            <p>{{ article.excerpt | strip_html | truncatewords: 22 }}</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- comment -%}
        Fallback preview cards — linked to page handles used by main-article-hub.liquid.
        These pages must exist in Shopify admin using the page.blog-article template.
      {%- endcomment -%}
      {%- assign filter_tag = current_tags | first | handle -%}

      <!-- Brand & Stories -->
      {%- if filter_tag == blank or filter_tag == 'brand-stories' -%}
        <a href="/pages/blog-about-tokiyo-lifestyle" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-1.png' | asset_url }}" alt="About Tokiyo Lifestyle" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Brand &amp; Stories</span>
            <p class="article-card__date">July 15, 2026</p>
            <h2>About Tokiyo Lifestyle</h2>
            <p>We believe clothing should do more than look good — it should tell a story, inspire confidence, and reflect individuality.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-story-behind-every-design" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-2.png' | asset_url }}" alt="Story Behind Every Design" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Brand &amp; Stories</span>
            <p class="article-card__date">July 14, 2026</p>
            <h2>The Story Behind Every Design</h2>
            <p>Every Tokiyo design starts with an idea, an emotion, or a story waiting to be told through wearable art.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
      {%- endif -%}

      <!-- Fashion & Styling -->
      {%- if filter_tag == blank or filter_tag == 'fashion-styling' -%}
        <a href="/pages/blog-streetwear-trends-india" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-3.png' | asset_url }}" alt="Streetwear Trends in India" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Fashion &amp; Styling</span>
            <p class="article-card__date">July 13, 2026</p>
            <h2>Streetwear Trends in India 2026</h2>
            <p>Today's generation values comfort, oversized silhouettes, bold graphics, and versatile outfits. Here's what's defining the scene.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-fashion-for-college-students" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-4.png' | asset_url }}" alt="Fashion for College Students" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Fashion &amp; Styling</span>
            <p class="article-card__date">July 12, 2026</p>
            <h2>Fashion for College Students</h2>
            <p>College is where you express your personality. Pair a premium graphic oversized tee with cargo pants and sneakers for the ultimate campus look.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-travel-outfit-ideas" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-1.png' | asset_url }}" alt="Travel Outfit Ideas" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Fashion &amp; Styling</span>
            <p class="article-card__date">July 11, 2026</p>
            <h2>Travel Outfit Ideas: Comfort Meets Style</h2>
            <p>The perfect travel outfit combines comfort, functionality, and effortless style for every journey. Here's how to nail it.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-weekend-outfit-inspiration" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-2.png' | asset_url }}" alt="Weekend Outfit Inspiration" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Fashion &amp; Styling</span>
            <p class="article-card__date">July 10, 2026</p>
            <h2>Weekend Outfit Inspiration</h2>
            <p>Weekends are perfect for relaxing and expressing your style. An oversized tee paired with cargos is always the right call.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-night-out-outfit" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-3.png' | asset_url }}" alt="Night Out Outfit" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Fashion &amp; Styling</span>
            <p class="article-card__date">July 9, 2026</p>
            <h2>Night Out Looks: Bold &amp; Comfortable</h2>
            <p>A premium oversized tee with black jeans and a jacket creates the perfect evening streetwear look that makes a statement.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
      {%- endif -%}

      <!-- Fabric & Quality -->
      {%- if filter_tag == blank or filter_tag == 'fabric-quality' -%}
        <a href="/pages/blog-why-fabric-quality-matters" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-4.png' | asset_url }}" alt="Why Fabric Quality Matters" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Fabric &amp; Quality</span>
            <p class="article-card__date">July 8, 2026</p>
            <h2>Why Fabric Quality Matters in Streetwear</h2>
            <p>Fabric quality is the foundation of every great T-shirt. It determines comfort, fit, and how long it keeps its shape.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-cotton-vs-cotton-blend" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-1.png' | asset_url }}" alt="Cotton vs Cotton Blend" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Fabric &amp; Quality</span>
            <p class="article-card__date">July 7, 2026</p>
            <h2>Cotton vs Cotton Blend: Which Is Better?</h2>
            <p>100% cotton offers natural softness. Blends offer durability. Here's the full breakdown to help you choose the right tee.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-dtf-printing-vs-screen-printing" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-2.png' | asset_url }}" alt="DTF vs Screen Printing" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Fabric &amp; Quality</span>
            <p class="article-card__date">July 6, 2026</p>
            <h2>DTF Printing vs Screen Printing Explained</h2>
            <p>DTF delivers vibrant colors for intricate designs. Screen printing suits bold large-run graphics. Know your tee before you buy.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
      {%- endif -%}

      <!-- Care Guides -->
      {%- if filter_tag == blank or filter_tag == 'care-guides' -%}
        <a href="/pages/blog-how-to-wash-printed-t-shirts" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-3.png' | asset_url }}" alt="How to Wash Printed T-Shirts" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Care Guides</span>
            <p class="article-card__date">July 5, 2026</p>
            <h2>How to Wash Printed T-Shirts the Right Way</h2>
            <p>Turn inside out, cold water, mild detergent, air dry in shade. These simple steps keep graphic tees looking new for years.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-how-to-prevent-fading" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-4.png' | asset_url }}" alt="How to Prevent Fading" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Care Guides</span>
            <p class="article-card__date">July 4, 2026</p>
            <h2>How to Prevent Fading on Your Favourite Tees</h2>
            <p>Avoid bleach, wash in cold water, and always air dry in shade to extend the life of your prints and keep colors vibrant.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
      {%- endif -%}

      <!-- Buying Guides -->
      {%- if filter_tag == blank or filter_tag == 'buying-guides' -%}
        <a href="/pages/blog-how-to-choose-oversized-fit" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-1.png' | asset_url }}" alt="Perfect Oversized Fit" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Buying Guides</span>
            <p class="article-card__date">July 3, 2026</p>
            <h2>How to Choose the Perfect Oversized Fit</h2>
            <p>The perfect oversized tee feels relaxed without looking baggy. Learn how shoulders, sleeves, and length create the ideal drape.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-best-t-shirt-colors-skin-tone" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-2.png' | asset_url }}" alt="T-Shirt Colors for Skin Tone" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Buying Guides</span>
            <p class="article-card__date">July 2, 2026</p>
            <h2>Best T-Shirt Colors for Every Skin Tone</h2>
            <p>The right color enhances your complexion. From deep charcoal to vibrant mustard — your complete color guide for Indian skin tones.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-beginners-streetwear-guide" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-3.png' | asset_url }}" alt="Beginner Streetwear Guide" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Buying Guides</span>
            <p class="article-card__date">July 1, 2026</p>
            <h2>Beginner's Guide to Streetwear in India</h2>
            <p>Start with an oversized tee, cargo pants, clean sneakers, and minimal accessories. Streetwear is a lifestyle, not just a trend.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
      {%- endif -%}

      <!-- Company Updates -->
      {%- if filter_tag == blank or filter_tag == 'company-updates' -%}
        <a href="/pages/blog-new-collection-launches" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-4.png' | asset_url }}" alt="New Collection Launches" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Company Updates</span>
            <p class="article-card__date">July 15, 2026</p>
            <h2>New Collection Launches at Tokiyo</h2>
            <p>Every new Tokiyo collection marks the beginning of a fresh story — released in limited quantities to celebrate conscious fashion.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
        <a href="/pages/blog-customer-stories" class="article-card hover-lift">
          <div class="article-card__image hover-zoom"><img src="{{ 'hero-slide-1.png' | asset_url }}" alt="Customer Stories" loading="lazy"></div>
          <div class="article-card__info">
            <span class="article-card__category">Company Updates</span>
            <p class="article-card__date">July 14, 2026</p>
            <h2>Customer Stories: Wearing Tokiyo Your Way</h2>
            <p>From college campuses and road trips to cafés — our community brings each design to life in its own authentic, unique way.</p>
            <span class="article-card__read-more">Read Entry →</span>
          </div>
        </a>
      {%- endif -%}

    {%- endif -%}
  </div>

  {%- if blog.articles.size > 0 -%}
    {%- paginate blog.articles by 9 -%}{% render 'pagination', paginate: paginate %}{%- endpaginate -%}
  {%- endif -%}
</div>

<style>
  .blog-page { padding-block: 2.5rem var(--spacing-sections, 64px); }
  .blog-header { text-align: center; max-width: 700px; margin: 0 auto 3rem; }
  .blog-header h1 { font-size: clamp(2rem, 4vw, 3.25rem); margin: 0.5rem 0 1.25rem; font-weight: 800; }
  .blog-header p { color: var(--color-text-muted, #767674); font-size: 1.05rem; line-height: 1.6; }
  
  .blog-categories {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3.5rem;
    border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.06));
    padding-bottom: 1.5rem;
  }
  .blog-category-link {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted, #767674);
    padding: 0.55rem 1.15rem;
    border-radius: 50px;
    border: 1px solid var(--color-border, rgba(0,0,0,0.08));
    background: #FFFFFF;
    transition: all 0.25s ease;
    text-decoration: none;
    white-space: nowrap;
  }
  .blog-category-link:hover {
    color: var(--color-primary, #000000);
    border-color: var(--color-primary, #000000);
    background: #f8f8f8;
  }
  .blog-category-link.is-active {
    background: var(--color-accent, #ff0000);
    color: #FFFFFF;
    border-color: var(--color-accent, #ff0000);
  }

  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  @media(max-width: 989px){ .blog-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } }
  @media(max-width: 600px){ .blog-grid { grid-template-columns: 1fr; } }
  
  .article-card {
    border-radius: 12px;
    overflow: hidden;
    background: #FFFFFF;
    border: 1px solid var(--color-border, rgba(0,0,0,0.06));
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: var(--color-primary, #000000);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .article-card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,0.1);
    transform: translateY(-4px);
  }
  .article-card__image { aspect-ratio: 16/10; overflow: hidden; position: relative; background: #111; }
  .article-card__image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
  .article-card:hover .article-card__image img { transform: scale(1.06); }
  .article-card__image--placeholder { background: linear-gradient(135deg, #111 0%, #333 100%); }
  .article-card__placeholder-bg { width: 100%; height: 100%; background: repeating-linear-gradient(45deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 1px, transparent 1px, transparent 8px); }
  
  .article-card__info { padding: 1.75rem; display: flex; flex-direction: column; flex-grow: 1; }
  .article-card__category {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent, #ff0000);
    margin-bottom: 0.4rem;
  }
  .article-card__date { font-size: 0.78rem; color: var(--color-text-muted, #767674); margin-bottom: 0.85rem; }
  .article-card__info h2 { font-size: 1.2rem; margin-bottom: 0.65rem; font-weight: 700; line-height: 1.35; }
  .article-card__info p { font-size: 0.9rem; color: var(--color-text-muted, #767674); line-height: 1.6; margin-bottom: 1.25rem; flex-grow: 1; }
  .article-card__read-more {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-primary, #000000);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: inline-flex;
    align-items: center;
    border-bottom: 1.5px solid var(--color-primary, #000000);
    width: fit-content;
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .article-card:hover .article-card__read-more {
    color: var(--color-accent, #ff0000);
    border-color: var(--color-accent, #ff0000);
  }
</style>

{% schema %}
{ "name": "Blog Posts", "tag": "section", "class": "section-blog" }
{% endschema %}
