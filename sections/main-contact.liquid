<div class="contact-page page-width">
  {% render 'breadcrumbs' %}
  <div class="contact-page__grid">
    <div class="contact-page__info animate-on-scroll fade-right">
      <h1>{{ 'templates.contact.title' | t }}</h1>
      <p>Have a question or feedback? We'd love to hear from you. Our team typically responds within 24 hours.</p>
      <div class="contact-info-block"><strong>Email</strong><p><a href="mailto:info@tokiyolifestyle.com">info@tokiyolifestyle.com</a></p></div>
      <div class="contact-info-block"><strong>Phone</strong><p>+91 98765 43210<br>Mon–Sat, 10am–7pm IST</p></div>
      <div class="contact-info-block"><strong>Headquarters</strong><p>Tokiyo Lifestyle<br>Bhubaneswar, Odisha</p></div>
    </div>
    <div class="contact-page__form animate-on-scroll fade-left">
      {%- form 'contact', id: 'ContactForm' -%}
        {%- if form.posted_successfully? -%}
          <div class="form-success">{{ 'templates.contact.success' | t }}</div>
        {%- endif -%}
        {%- if form.errors -%}
          <div class="form-errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div class="form-row">
          <div class="form-field">
            <label for="ContactName">{{ 'templates.contact.name' | t }}</label>
            <input type="text" name="contact[name]" id="ContactName" value="{{ form.name }}" autocomplete="name" required>
          </div>
          <div class="form-field">
            <label for="ContactEmail">{{ 'templates.contact.email' | t }}</label>
            <input type="email" name="contact[email]" id="ContactEmail" value="{{ form.email }}" autocomplete="email" required>
          </div>
        </div>
        <div class="form-field">
          <label for="ContactPhone">{{ 'templates.contact.phone' | t }}</label>
          <input type="tel" name="contact[phone]" id="ContactPhone" value="{{ form.phone }}" autocomplete="tel">
        </div>
        <div class="form-field">
          <label for="ContactMessage">{{ 'templates.contact.message' | t }}</label>
          <textarea name="contact[body]" id="ContactMessage" rows="5" required>{{ form.body }}</textarea>
        </div>
        <button type="submit" class="button button--solid">{{ 'templates.contact.submit' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</div>
<style>
  .contact-page { padding-block: 3.5rem 5rem; background: var(--color-background, #FFFFFF); }
  .contact-page__grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: 5rem; align-items: start; }
  @media(max-width: 749px){ .contact-page__grid { grid-template-columns: 1fr; gap: 3rem; } }
  .contact-page__info h1 { font-size: clamp(1.75rem, 3vw, 2.5rem); margin-bottom: 1.25rem; font-weight: 700; letter-spacing: -0.01em; }
  .contact-page__info > p { color: var(--color-text-muted, #767674); line-height: 1.7; margin-bottom: 2rem; }
  .contact-info-block { margin-top: 2rem; border-top: 1px solid var(--color-border, rgba(0,0,0,0.06)); padding-top: 1.25rem; }
  .contact-info-block strong { display: block; margin-bottom: .5rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent, #ff0000); }
  .contact-info-block p { color: var(--color-primary, #111111); font-size: .9375rem; line-height: 1.6; }
  .contact-info-block a { text-decoration: underline; transition: color 0.2s; }
  .contact-info-block a:hover { color: var(--color-accent, #ff0000); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  @media(max-width: 480px){ .form-row { grid-template-columns: 1fr; gap: 0; } }
  .form-field { margin-bottom: 2rem; }
  .form-field label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted, #767674);
    margin-bottom: 0.35rem;
  }
  .form-success { padding: 1rem; background: rgba(46,125,50,0.08); border-left: 3px solid #2E7D32; color: #2E7D32; margin-bottom: 2rem; font-weight: 600; font-size: 0.875rem; }
  .form-errors { padding: 1rem; background: rgba(198,40,40,0.08); border-left: 3px solid #C62828; color: #C62828; margin-bottom: 2rem; font-weight: 600; font-size: 0.875rem; }
</style>
{% schema %}
{ "name": "Contact Page", "tag": "section", "class": "section-contact" }
{% endschema %}
