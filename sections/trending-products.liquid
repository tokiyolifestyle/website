{%- comment -%} Trending Products — Dark Premium with Coming Soon {%- endcomment -%}

<section class="trending-products section-trending-products">
  <div class="page-width">
    <div class="section-header-block animate-on-scroll fade-up">
      <p class="text-eyebrow">{{ section.settings.eyebrow | default: 'Trending Now' }}</p>
      <h2>{{ section.settings.title | default: 'Bestsellers' }}</h2>
    </div>

    {%- comment -%} Dynamically build mixed Men's and Women's products list {%- endcomment -%}
    {%- assign men_oversized_col = collections['men-oversized'] -%}
    {%- assign men_regular_col = collections['men-regular'] -%}
    {%- assign women_oversized_col = collections['women-oversized'] -%}
    
    {%- assign men_handles = '' -%}
    {%- assign women_handles = '' -%}

    {%- comment -%} Get Men's products {%- endcomment -%}
    {%- if men_oversized_col != blank -%}
      {%- for p in men_oversized_col.products -%}
        {%- assign men_handles = men_handles | append: p.handle | append: ',' -%}
      {%- endfor -%}
    {%- endif -%}
    {%- if men_regular_col != blank -%}
      {%- for p in men_regular_col.products -%}
        {%- assign men_handles = men_handles | append: p.handle | append: ',' -%}
      {%- endfor -%}
    {%- endif -%}

    {%- comment -%} Get Women's products {%- endcomment -%}
    {%- if women_oversized_col != blank -%}
      {%- for p in women_oversized_col.products -%}
        {%- assign women_handles = women_handles | append: p.handle | append: ',' -%}
      {%- endfor -%}
    {%- endif -%}

    {%- assign men_handles_array = men_handles | split: ',' -%}
    {%- assign women_handles_array = women_handles | split: ',' -%}
    
    {%- assign max_limit = section.settings.limit | default: 8 -%}
    {%- assign rendered_count = 0 -%}

    <div class="product-grid product-grid--{{ section.settings.columns }}" data-product-grid>
      {%- for i in (0..30) -%}
        {%- if rendered_count >= max_limit -%}{%- break -%}{%- endif -%}
        
        {%- comment -%} Alternating between Men's and Women's {%- endcomment -%}
        {%- assign select_men = true -%}
        {%- assign mod_check = i | modulo: 2 -%}
        {%- if mod_check == 1 -%}
          {%- assign select_men = false -%}
        {%- endif -%}

        {%- assign target_product = blank -%}
        {%- if select_men -%}
          {%- comment -%} Use multiplier offset to skip identical color options of the same design {%- endcomment -%}
          {%- assign m_idx = i | divided_by: 2 | times: 3 | modulo: men_handles_array.size -%}
          {%- assign m_handle = men_handles_array[m_idx] -%}
          {%- if m_handle != blank -%}
            {%- assign target_product = all_products[m_handle] -%}
          {%- endif -%}
        {%- else -%}
          {%- assign w_idx = i | divided_by: 2 | times: 3 | modulo: women_handles_array.size -%}
          {%- assign w_handle = women_handles_array[w_idx] -%}
          {%- if w_handle != blank -%}
            {%- assign target_product = all_products[w_handle] -%}
          {%- endif -%}
        {%- endif -%}

        {%- if target_product != blank -%}
          {% render 'product-card', product: target_product, lazy: true %}
          {%- assign rendered_count = rendered_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- else -%}
      {%- comment -%} Coming Soon Products Placeholder {%- endcomment -%}
      <div class="product-grid product-grid--{{ section.settings.columns | default: 4 }} stagger-children">
        {%- assign placeholder_products = "Oversized Tee,Cargo Pants,Puffer Jacket,Sneakers,Crossbody Bag,Denim Jacket,Wide Leg Pants,Beanie Cap,Hoodie,Chain Necklace" | split: "," -%}
        {%- assign placeholder_prices = "1499,2499,3999,2999,1999,3499,2299,999,2799,1299" | split: "," -%}
        {%- assign placeholder_compare = "2499,3999,5999,4499,3499,4999,3499,1499,3999,1999" | split: "," -%}
        {%- assign placeholder_ratings = "4.8,4.6,4.9,4.7,4.5,4.8,4.4,4.3,4.9,4.6" | split: "," -%}
        {%- assign placeholder_reviews = "124,89,56,203,67,145,78,34,187,92" | split: "," -%}
        {%- assign placeholder_cats = "Men's,Men's,Winterwear,Footwear,Accessories,Men's,Women's,Accessories,Winterwear,Accessories" | split: "," -%}

        {%- for item in placeholder_products limit: section.settings.limit -%}
          <div class="product-card">
            <div class="product-card__media">
              <div class="coming-soon-placeholder">
                <div class="coming-soon-placeholder__inner">
                  <span class="coming-soon-placeholder__icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                  </span>
                  <span class="coming-soon-placeholder__text">Coming Soon</span>
                </div>
              </div>
              <span class="badge badge--new">New</span>
            </div>
            <div class="product-card__info">
              <p class="product-card__vendor">{{ placeholder_cats[forloop.index0] }}</p>
              <h3 class="product-card__title">{{ item }}</h3>
              <div class="product-card__price">
                <span class="price--sale">₹{{ placeholder_prices[forloop.index0] }}</span>
                <span class="price--compare">₹{{ placeholder_compare[forloop.index0] }}</span>
              </div>
              <div class="product-card__rating">
                <div class="product-card__stars">
                  {%- for i in (1..5) -%}
                    <svg viewBox="0 0 20 20"><path d="M10 1l2.39 6.56H19l-5.3 4.04 1.97 6.56L10 14.24l-5.67 3.92 1.97-6.56L1 7.56h6.61z"/></svg>
                  {%- endfor -%}
                </div>
                <span class="product-card__rating-count">{{ placeholder_ratings[forloop.index0] }} ({{ placeholder_reviews[forloop.index0] }})</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div style="text-align:center;margin-top:3rem;" class="animate-on-scroll fade-up">
        <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="button button--outline">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .trending-products { padding: var(--spacing-sections, 64px) 0; background: var(--color-background, #FFFFFF); }

  .coming-soon-placeholder {
    width:100%; height:100%; aspect-ratio:3/4;
    background: #F4F4F3;
    display:flex; align-items:center; justify-content:center;
    position:relative;
  }
  .coming-soon-placeholder__inner {
    text-align:center; z-index:1;
  }
  .coming-soon-placeholder__icon {
    display:block; margin-bottom:0.5rem;
    color: var(--color-accent, #ff0000); opacity:0.6;
  }
  .coming-soon-placeholder__text {
    font-size:0.6875rem; text-transform:uppercase; letter-spacing:0.15em;
    color: var(--color-text-muted, #767674); font-weight:600;
  }

  .coming-soon-placeholder .badge--new {
    position:absolute; top:12px; left:12px;
  }
  .product-card__media .badge--new {
    position:absolute; top:12px; left:12px; z-index:2;
  }
</style>

{% schema %}
{
  "name": "Trending Products",
  "tag": "section",
  "class": "section-trending-products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Trending Now" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Bestsellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 4, "max": 12, "step": 1, "label": "Products to show", "default": 8 },
    { "type": "range", "id": "columns", "min": 2, "max": 5, "step": 1, "label": "Columns", "default": 4 },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "View All Products" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Trending Products" }]
}
{% endschema %}
