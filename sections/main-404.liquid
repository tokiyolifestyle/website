  <div class="wishlist-page page-width">
    {% render 'breadcrumbs' %}
    <div class="wishlist-page__header">
      <span class="text-eyebrow">Your Selection</span>
      <h1>My Wishlist</h1>
    </div>
    <div class="wishlist-grid-wrapper">
      <div class="wishlist-grid" data-wishlist-grid></div>
    </div>
  </div>
