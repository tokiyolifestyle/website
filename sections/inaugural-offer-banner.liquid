<div class="inaugural-banner" style="background: #0A0A0A; border-top: 1px solid rgba(197, 168, 128, 0.25); border-bottom: 1px solid rgba(197, 168, 128, 0.25);">
  <div class="inaugural-banner__inner page-width">
    <div class="inaugural-banner__badge">
      <span class="inaugural-banner__badge-icon">🎉</span>
      <span class="inaugural-banner__badge-text">Inaugural Offer</span>
    </div>
    <div class="inaugural-banner__content">
      Get <strong class="highlight-text" style="color: var(--color-accent, #ff0000);">10% OFF</strong> on your first order! 
      <span class="banner-divider">|</span>
      <span class="promo-code-wrap">
        Use code: <span class="promo-code-box" id="PromoCodeBox" onclick="copyPromoCode(this)" style="cursor: pointer;" title="Click to copy">TOKIYO10</span>
      </span>
    </div>
    <div class="inaugural-banner__right">
      First 1000 Customers Only
    </div>
  </div>
</div>

<script>
  function copyPromoCode(el) {
    navigator.clipboard.writeText('TOKIYO10');
    const originalText = el.innerText;
    el.innerText = 'COPIED!';
    el.style.borderColor = '#25D366';
    el.style.color = '#25D366';
    setTimeout(() => {
      el.innerText = originalText;
      el.style.borderColor = '';
      el.style.color = '';
    }, 1500);
  }
</script>

<style>
  .inaugural-banner {
    padding: 0.4rem 0;
    color: #FFFFFF;
    font-family: var(--font-body), sans-serif;
    border-top: 1px solid rgba(197, 168, 128, 0.25);
    border-bottom: 1px solid rgba(197, 168, 128, 0.25);
    overflow: hidden;
  }
  .inaugural-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .banner-divider {
    margin: 0 0.5rem;
    opacity: 0.5;
  }
  .promo-code-wrap {
    display: inline-block;
  }
  @media(max-width: 749px) {
    .inaugural-banner__badge {
      display: none !important;
    }
    .inaugural-banner__right {
      display: none !important;
    }
    .inaugural-banner {
      padding: 0.25rem 0 !important;
    }
    .inaugural-banner__content {
      font-size: 0.78rem !important;
      line-height: 1.4 !important;
    }
    .inaugural-banner__inner {
      flex-direction: column;
      justify-content: center;
      text-align: center;
      gap: 0 !important;
    }
    .banner-divider {
      display: none;
    }
    .promo-code-wrap {
      display: block;
      margin-top: 0.15rem;
    }
    .promo-code-box {
      margin-left: 0.25rem;
    }
  }
  .inaugural-banner__badge {
    background: rgba(197, 168, 128, 0.15);
    border: 1px solid rgba(197, 168, 128, 0.3);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent, #ff0000);
  }
  .inaugural-banner__content {
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    font-weight: 500;
  }
  .highlight-text {
    font-weight: 800;
  }
  .promo-code-box {
    display: inline-block;
    border: 2px dashed var(--color-accent, #ff0000);
    background: rgba(197, 168, 128, 0.08);
    color: var(--color-accent, #ff0000);
    padding: 0.25rem 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-left: 0.5rem;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.9rem;
  }
  .inaugural-banner__right {
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-accent, #ff0000);
    opacity: 0.95;
  }
</style>

