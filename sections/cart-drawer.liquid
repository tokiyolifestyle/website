<{%- assign cart_item_count = 0 -%}
{%- assign cart_subtotal_cents = 0 -%}
{%- for item in cart.items -%}
  {%- if item.variant_id == 48862017716468 -%}{%- continue -%}{%- endif -%}
  {%- assign cart_item_count = cart_item_count | plus: item.quantity -%}
  {%- assign cart_subtotal_cents = cart_subtotal_cents | plus: item.final_line_price -%}
{%- endfor -%}

<div class="cart-drawer-overlay" data-cart-overlay></div>

<div class="cart-drawer" data-cart-drawer id="CartDrawer" aria-label="Cart" role="dialog" aria-modal="true" style="transform: translateX(100%); visibility: hidden;">
  <form action="{{ routes.cart_url }}" method="post" id="CartDrawerForm" style="display: flex; flex-direction: column; height: 100%; width: 100%; overflow: hidden; margin: 0;">
    {%- comment -%} Header stays fixed, everything below scrolls as one unit {%- endcomment -%}
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">{{ 'sections.cart.title' | t }} (<span data-cart-count>{{ cart_item_count }}</span>)</h2>
      <button class="cart-drawer__close" data-cart-drawer-close type="button" aria-label="{{ 'accessibility.close' | t }}">{% render 'icon-close' %}</button>
    </div>

    {%- if settings.cart_free_shipping_bar -%}
      {%- assign threshold = settings.cart_free_shipping_threshold | plus: 0 -%}
      <div class="cart-drawer__shipping-bar" data-shipping-bar data-free-shipping-threshold="{{ threshold }}">
        <p data-shipping-message>
          {%- assign threshold_cents = threshold | times: 100 -%}
          {%- if cart_subtotal_cents >= threshold_cents -%}
            {{ 'sections.cart.free_shipping_achieved' | t }}
          {%- else -%}
            {%- assign remaining = threshold_cents | minus: cart_subtotal_cents | divided_by: 100.0 -%}
            Add ₹{{ remaining | floor }} more for FREE shipping!
          {%- endif -%}
        </p>
        <div class="cart-drawer__progress">
          {%- assign progress_pct = cart_subtotal_cents | times: 100 | divided_by: threshold_cents | at_most: 100 -%}
          <div class="cart-drawer__progress-bar" data-shipping-progress style="width:{{ progress_pct }}%;"></div>
        </div>
      </div>
    {%- endif -%}

    <div class="cart-drawer__body" data-cart-body style="overflow-y: auto; -webkit-overflow-scrolling: touch;">
      {%- if cart.item_count > 0 -%}
        {%- for item in cart.items -%}
          {%- if item.variant_id == 48862017716468 -%}{%- continue -%}{%- endif -%}
          <div class="cart-item" data-cart-item="{{ item.key }}">
            <div class="cart-item__image" style="background: #F8F7F5;">
              {%- if item.image -%}
                {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy', style: 'mix-blend-mode: multiply;', alt: item.title | escape }}
              {%- else -%}
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            <div class="cart-item__details">
              <div class="cart-item__header">
                <a href="{{ item.url }}" class="cart-item__title" style="text-decoration: none;">{{ item.product.title }}</a>
                <button class="cart-item__remove-btn" data-cart-remove="{{ item.key }}" type="button" aria-label="Remove">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                </button>
              </div>
              {%- unless item.product.has_only_default_variant -%}<p class="cart-item__variant">{{ item.variant.title }}</p>{%- endunless -%}
              
              <div class="cart-item__bottom">
                <p class="cart-item__price">{{ item.final_price | money }}</p>
                <div class="cart-item__qty" style="margin-top: 0;">
                  <button type="button" class="cart-item__qty-btn" data-qty-change="-1" aria-label="Decrease">{% render 'icon-minus' %}</button>
                  <input class="cart-item__qty-input" data-qty-input type="number" value="{{ item.quantity }}" min="0" aria-label="Quantity">
                  <button type="button" class="cart-item__qty-btn" data-qty-change="1" aria-label="Increase">{% render 'icon-plus' %}</button>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}

        <!-- --- Payment Option Selector inside body (scrollable) --- -->
        <div class="cart-payment-methods">
          <label class="payment-methods-title">Select Payment Method</label>
          <div class="payment-options-grid">
            <label class="payment-option-card active" id="PrepaidOptionCard">
              <input type="radio" name="payment_method_choice" value="prepaid" checked onchange="updatePaymentMethod(this.value)">
              <span class="option-indicator"></span>
              <div class="option-details">
                <strong>Prepaid (Online)</strong>
                <p>UPI/Card/Netbanking — Free Shipping</p>
              </div>
            </label>
            <label class="payment-option-card" id="CodOptionCard">
              <input type="radio" name="payment_method_choice" value="cod" onchange="updatePaymentMethod(this.value)">
              <span class="option-indicator"></span>
              <div class="option-details">
                <strong>Cash on Delivery (COD)</strong>
                <p>Extra ₹80 (Free above ₹1199)</p>
              </div>
            </label>
          </div>
          <div class="payment-methods-notice" id="PaymentPrepaidNotice" style="margin-top: 0.75rem; font-size: 0.7rem; color: #555; line-height: 1.3;">
             ✓ Prepaid orders get <strong>FREE shipping</strong>! 🎁
          </div>
          <div class="payment-methods-notice" id="PaymentCodNotice" style="margin-top: 0.75rem; font-size: 0.72rem; color: #b71c1c; line-height: 1.4; display: none; background: rgba(183, 28, 28, 0.04); border-left: 2px solid #b71c1c; padding: 0.4rem 0.6rem;">
             ⚠️ <strong>Switching to Razorpay at checkout?</strong> Please change your selection to 'Prepaid' here first to remove the ₹80 COD fee.
          </div>
        </div>

        {%- if settings.cart_show_gift_note -%}
          <div class="cart-drawer__note" style="margin: 1.5rem 0 1rem; border-top: 1px dashed #eee; padding-top: 1rem;">
            <label for="CartNote" class="payment-methods-title" style="margin-bottom: 0.5rem;">{{ 'sections.cart.gift_note' | t }}</label>
            <textarea id="CartNote" name="note" data-cart-note placeholder="Enter your gift message..." rows="2" style="background: #fcfcfc;">{{ cart.note }}</textarea>
          </div>
        {%- endif -%}
        
        <p class="cart-drawer__taxes-note" style="margin-bottom: 1rem;">Shipping calculated at checkout. Price is inclusive of GST.</p>
        <a href="/cart" class="button button--outline button--full" style="font-size:0.8rem; padding: 0.6rem;">{{ 'sections.cart.view_cart' | t }}</a>

      {%- else -%}
        <div class="cart-drawer__empty">
          <p>{{ 'sections.cart.empty' | t }}</p>
          <a href="/collections/all" class="button button--solid">{{ 'sections.cart.start_shopping' | t }}</a>
        </div>
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer" data-cart-footer>
        <div class="cart-drawer__subtotal" id="CartCodFeeRow" style="display: none; margin-bottom: 0.25rem; color: #C62828; font-size: 0.8rem;">
          <span>COD Shipping Fee</span>
          <span>+₹80.00</span>
        </div>

        <div class="cart-drawer__subtotal" style="font-size: 1.1rem; margin-bottom: 0.75rem;">
          <span>{{ 'sections.cart.subtotal' | t }}</span>
          <span id="DrawerTotalPriceDisplay">{{ cart_subtotal_cents | money }}</span>
        </div>

        <script>
          window.cartSubtotalCents = {{ cart_subtotal_cents }};
        </script>

        <div class="cart-drawer__checkout">
          <button type="submit" name="checkout" class="button button--solid button--full">{{ 'sections.cart.checkout' | t }}</button>
        </div>
      </div>
    {%- endif -%}
  </form>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "tag": "div",
  "class": "section-cart-drawer"
}
{% endschema %}
