<section class="hero-banner section-hero-banner" style="--hero-height:{{ section.settings.hero_height }}vh;">
  <div class="hero-banner__media parallax-container">
    {%- if section.settings.video_url != blank -%}
      <video class="hero-banner__video" autoplay muted loop playsinline aria-hidden="true">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        widths: '750, 1100, 1440, 1920',
        sizes: '100vw',
        class: 'hero-banner__img',
        alt: section.settings.image.alt | escape
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-banner__img hero-banner__placeholder' }}
    {%- endif -%}
    <div class="hero-banner__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};background:{{ section.settings.overlay_color }};"></div>
  </div>

  <div class="hero-banner__content page-width hero-banner__content--{{ section.settings.content_alignment }}">
    {%- if section.settings.eyebrow != blank -%}
      <p class="text-eyebrow animate-on-scroll fade-up" style="color:{{ section.settings.eyebrow_color }};">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="hero-banner__heading animate-on-scroll fade-up" style="color:{{ section.settings.text_color }};">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="hero-banner__subheading animate-on-scroll fade-up" style="color:{{ section.settings.text_color }};">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div class="hero-banner__ctas animate-on-scroll fade-up">
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link }}" class="button button--solid">{{ section.settings.cta_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta2_label != blank -%}
        <a href="{{ section.settings.cta2_link }}" class="button button--outline" style="color:{{ section.settings.text_color }};border-color:{{ section.settings.text_color }};">{{ section.settings.cta2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .hero-banner { position:relative; height:var(--hero-height, 90vh); min-height:480px; display:flex; align-items:center; overflow:hidden; }
  .hero-banner__media { position:absolute; inset:0; z-index:0; }
  .hero-banner__img { width:100%; height:100%; object-fit:cover; }
  .hero-banner__placeholder { width:100%; height:100%; }
  .hero-banner__video { width:100%; height:100%; object-fit:cover; }
  .hero-banner__overlay { position:absolute; inset:0; }
  .hero-banner__content { position:relative; z-index:2; width:100%; }
  .hero-banner__content--center { text-align:center; }
  .hero-banner__content--right  { text-align:right; }
  .hero-banner__heading { font-size:clamp(2.5rem,6vw,5rem); font-weight:800; line-height:1.05; margin-bottom:1rem; }
  .hero-banner__subheading { font-size:1.1rem; max-width:520px; margin-bottom:2rem; opacity:0.9; }
  .hero-banner__content--center .hero-banner__subheading { margin-inline:auto; }
  .hero-banner__ctas { display:flex; gap:1rem; flex-wrap:wrap; }
  .hero-banner__content--center .hero-banner__ctas { justify-content:center; }
  .hero-banner__content--right .hero-banner__ctas { justify-content:flex-end; }
  @media(max-width:749px){ .hero-banner { height:70vh; } .hero-banner__heading { font-size:2.25rem; } }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "video_url", "label": "Video URL (.mp4)", "info": "Overrides image if set" },
    { "type": "range", "id": "hero_height", "min": 40, "max": 100, "step": 5, "unit": "vh", "label": "Banner height", "default": 90 },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "label": "Overlay opacity", "default": 30 },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
    { "type": "select", "id": "content_alignment", "label": "Content alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "New Collection" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#C9A86A" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Dress Your Best,\nEvery Day." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Premium fashion essentials crafted for the modern wardrobe." },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "text", "id": "cta_label", "label": "Primary button label", "default": "Shop Now" },
    { "type": "url",  "id": "cta_link",  "label": "Primary button link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary button label", "default": "Explore Collections" },
    { "type": "url",  "id": "cta2_link",  "label": "Secondary button link" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
