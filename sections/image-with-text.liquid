{%- comment -%} Image with Text — Dark Premium {%- endcomment -%}

<section class="iwt section-iwt" style="background:{{ section.settings.background_color | default: '#0A0A0A' }};">
  <div class="page-width">
    <div class="iwt__grid iwt__grid--{{ section.settings.layout }}">
      <div class="iwt__media animate-on-scroll {% if section.settings.layout == 'image-right' %}fade-left{% else %}fade-right{% endif %}">
        {%- assign iwt_image = section.settings.image -%}
        {%- if iwt_image == blank and collections['men-oversized'] != blank and collections['men-oversized'].products.first != blank -%}
          {%- assign iwt_image = collections['men-oversized'].products.first.featured_image -%}
        {%- endif -%}
        {%- if iwt_image != blank -%}
          {{ iwt_image | image_url: width: 900 | image_tag:
            loading: 'lazy',
            widths: '450, 700, 900',
            sizes: '(max-width:749px) 100vw, 50vw',
            class: 'iwt__img'
          }}
        {%- else -%}
          <div class="iwt__placeholder">
            <div class="iwt__placeholder-pattern"></div>
          </div>
        {%- endif -%}
      </div>
      <div class="iwt__content animate-on-scroll {% if section.settings.layout == 'image-right' %}fade-right{% else %}fade-left{% endif %}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="text-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 style="color:{{ section.settings.text_color | default: '#FFFFFF' }};">{{ section.settings.heading }}</h2>
        <div class="iwt__body" style="color:{{ section.settings.text_color | default: 'rgba(255,255,255,0.6)' }};">
          {{ section.settings.body }}
        </div>
        {%- if section.settings.features != blank -%}
          <ul class="iwt__features">
            {%- assign features = section.settings.features | split: '|' -%}
            {%- for feature in features -%}
              <li>
                <span class="iwt__check">✦</span>
                {{ feature | strip }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link }}" class="button button--solid">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .iwt { padding:6rem 0; }
  .iwt__grid { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; }
  .iwt__grid--image-right .iwt__media { order:2; }
  .iwt__img { width:100%; height:auto; }
  .iwt__placeholder {
    aspect-ratio:4/5; background:linear-gradient(135deg, #141414, #1a1a1a);
    display:flex; align-items:center; justify-content:center;
  }
  .iwt__placeholder-pattern {
    width:100%; height:100%;
    background-image: radial-gradient(circle at 30% 40%, rgba(201,168,106,0.08) 0%, transparent 50%);
  }
  .iwt__content h2 { margin-bottom:1rem; }
  .iwt__body { margin-bottom:1.5rem; line-height:1.8; color:rgba(255,255,255,0.6); }
  .iwt__body p, .iwt__body span, .iwt__body strong, .iwt__body a, .iwt__body font { color: inherit !important; }
  .iwt__features { margin:1.5rem 0 2rem; }
  .iwt__features li {
    display:flex; align-items:center; gap:0.75rem;
    padding:0.5rem 0; color:rgba(255,255,255,0.7) !important;
    font-size:0.9375rem;
  }
  .iwt__features li * { color: inherit !important; }
  .iwt__check { color:var(--color-accent, #ff0000); font-size:0.75rem; }
  @media(max-width:749px){
    .iwt__grid { grid-template-columns:1fr; gap:2rem; }
    .iwt__grid--image-right .iwt__media { order:0; }
    .iwt { padding:3rem 0; }
  }
</style>

{% schema %}
{
  "name": "Image with Text",
  "tag": "section",
  "class": "section-iwt",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [{"value":"image-left","label":"Image left"},{"value":"image-right","label":"Image right"}], "default": "image-left" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Crafted for the Bold" },
    { "type": "richtext", "id": "body", "label": "Body text", "default": "<p>At Tokiyo Lifestyle, we believe fashion is more than clothing — it's a statement. Every piece is designed with precision and crafted from premium materials for the modern individual.</p>" },
    { "type": "text", "id": "features", "label": "Features (separate with |)", "default": "Premium Quality Fabrics|Ethically Sourced Materials|Designed in India|Free Shipping on Prepaid Orders" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Discover More" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#0A0A0A" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" }
  ],
  "presets": [{ "name": "Image with Text" }]
}
{% endschema %}
