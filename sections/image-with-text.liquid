<section class="image-with-text section-image-with-text">
  <div class="page-width">
    <div class="image-with-text__grid image-with-text__grid--{{ section.settings.layout }}">
      <div class="image-with-text__media animate-on-scroll {% if section.settings.layout == 'text_first' %}fade-right{% else %}fade-left{% endif %} hover-zoom">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 900 | image_tag:
            loading: 'lazy',
            widths: '450, 700, 900',
            sizes: '(max-width:749px) 100vw, 50vw',
            alt: section.settings.image.alt | escape
          }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'image-with-text__placeholder' }}
        {%- endif -%}
      </div>
      <div class="image-with-text__content animate-on-scroll {% if section.settings.layout == 'text_first' %}fade-left{% else %}fade-right{% endif %}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="text-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2>{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="image-with-text__text rte">{{ section.settings.text }}</div>
        {%- endif -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div class="image-with-text__feature" {{ block.shopify_attributes }}>
              <span class="image-with-text__feature-icon">{{ block.settings.emoji | default: '✓' }}</span>
              <div>
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link }}" class="button button--solid">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .image-with-text__grid { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; }
  .image-with-text__grid--text_first .image-with-text__media { order:2; }
  .image-with-text__grid--text_first .image-with-text__content { order:1; }
  @media(max-width:749px) {
    .image-with-text__grid { grid-template-columns:1fr; gap:2rem; }
    .image-with-text__grid--text_first .image-with-text__media { order:1; }
    .image-with-text__grid--text_first .image-with-text__content { order:2; }
  }
  .image-with-text__media { border-radius:var(--card-radius,12px); overflow:hidden; aspect-ratio:4/5; }
  .image-with-text__media img,.image-with-text__placeholder { width:100%; height:100%; object-fit:cover; }
  .image-with-text__content h2 { font-size:clamp(1.75rem,3vw,2.75rem); margin-bottom:1rem; }
  .image-with-text__text { color:#555; line-height:1.75; margin-bottom:1.5rem; }
  .image-with-text__feature { display:flex; gap:.75rem; align-items:flex-start; margin-bottom:1rem; }
  .image-with-text__feature-icon { font-size:1.25rem; }
  .image-with-text__feature strong { display:block; margin-bottom:.25rem; }
  .image-with-text__feature p { font-size:.875rem; color:#666; margin:0; }
  .image-with-text__content .button { margin-top:1.5rem; }
</style>

{% schema %}
{
  "name": "Image with Text",
  "tag": "section",
  "class": "section-image-with-text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [{"value":"image_first","label":"Image left, text right"},{"value":"text_first","label":"Text left, image right"}], "default": "image_first" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Crafted With Purpose" },
    { "type": "richtext", "id": "text", "label": "Description", "default": "<p>Every piece in the Tokiyo collection is designed with intent — quality materials, considered cuts, and details that matter.</p>" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Discover Our Story" },
    { "type": "url",  "id": "cta_link",  "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature point",
      "settings": [
        { "type": "text", "id": "emoji",  "label": "Icon / Emoji", "default": "✓" },
        { "type": "text", "id": "title",  "label": "Title",        "default": "Premium Materials" },
        { "type": "text", "id": "text",   "label": "Description",  "default": "Soft, breathable fabrics built to last." }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "feature", "settings": { "emoji": "✓", "title": "Premium Fabrics", "text": "GOTS-certified organic cotton and sustainable blends." } },
      { "type": "feature", "settings": { "emoji": "✓", "title": "Ethical Production", "text": "Made in fair-trade certified facilities." } },
      { "type": "feature", "settings": { "emoji": "✓", "title": "Designed to Last", "text": "Timeless silhouettes that outlast fast fashion." } }
    ]
  },
  "presets": [{ "name": "Image with Text" }]
}
{% endschema %}
