<section class="featured-collections section-featured-collections">
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="section-header-block animate-on-scroll fade-up">
        {%- if section.settings.eyebrow != blank -%}<p class="text-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        {%- if section.settings.title != blank -%}<h2>{{ section.settings.title }}</h2>{%- endif -%}
        {%- if section.settings.subtitle != blank -%}<p>{{ section.settings.subtitle }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="featured-collections__grid stagger-children" style="grid-template-columns:repeat({{ section.settings.columns }},1fr);">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        <a href="{{ block.settings.link | default: coll.url | default: '/collections/all' }}" class="collection-card hover-lift" {{ block.shopify_attributes }}>
          <div class="collection-card__media hover-zoom">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(max-width:749px) 50vw, 25vw',
                alt: block.settings.title | escape
              }}
            {%- elsif coll != blank and coll.featured_image != blank -%}
              {{ coll.featured_image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(max-width:749px) 50vw, 25vw',
                alt: coll.title | escape
              }}
            {%- else -%}
              {{ 'collection-apparel-1' | placeholder_svg_tag: 'collection-card__placeholder' }}
            {%- endif -%}
            <div class="collection-card__overlay"></div>
          </div>
          <div class="collection-card__info">
            <h3>{{ block.settings.title | default: coll.title | default: 'Collection' }}</h3>
            {%- if block.settings.subtitle != blank -%}<p>{{ block.settings.subtitle }}</p>{%- endif -%}
            <span class="collection-card__cta">Shop Now {% render 'icon-chevron-right' %}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="section-cta animate-on-scroll fade-up">
        <a href="{{ section.settings.cta_link | default: '/collections' }}" class="button button--outline">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .featured-collections__grid { display:grid; gap:var(--grid-gutter,20px); }
  @media(max-width:749px) { .featured-collections__grid { grid-template-columns:repeat(2,1fr) !important; } }
  .collection-card { display:block; border-radius:var(--card-radius,12px); overflow:hidden; position:relative; }
  .collection-card__media { aspect-ratio:3/4; background:#eee; position:relative; }
  .collection-card__media img,.collection-card__placeholder { width:100%; height:100%; object-fit:cover; }
  .collection-card__overlay { position:absolute; inset:0; background:linear-gradient(to top, rgba(17,17,17,.55) 0%, transparent 55%); }
  .collection-card__info { position:absolute; bottom:0; left:0; right:0; padding:1.25rem; color:#fff; }
  .collection-card__info h3 { font-size:1.1rem; margin-bottom:.2rem; }
  .collection-card__info p { font-size:.8125rem; opacity:.85; margin-bottom:.5rem; }
  .collection-card__cta { display:inline-flex; align-items:center; gap:4px; font-size:.8125rem; font-weight:600; text-decoration:underline; text-underline-offset:3px; }
  .section-cta { text-align:center; margin-top:2.5rem; }
</style>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "section-featured-collections",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop By Category" },
    { "type": "text", "id": "title", "label": "Title", "default": "Explore Collections" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Curated edits for every occasion and style." },
    { "type": "range", "id": "columns", "min": 2, "max": 5, "step": 1, "label": "Columns (desktop)", "default": 4 },
    { "type": "text", "id": "cta_label", "label": "View all label", "default": "View All Collections" },
    { "type": "url",  "id": "cta_link",  "label": "View all link" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image" },
        { "type": "text", "id": "title", "label": "Label" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "url",  "id": "link",  "label": "Link override" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "collection", "settings": { "title": "Men's Essentials" } },
      { "type": "collection", "settings": { "title": "Women's Edit" } },
      { "type": "collection", "settings": { "title": "Oversized Tees" } },
      { "type": "collection", "settings": { "title": "Hoodies & Sweatshirts" } }
    ]
  },
  "presets": [{ "name": "Featured Collections" }]
}
{% endschema %}
