<div class="page-content page-width">
  {% render 'breadcrumbs' %}
  <div class="page-content__header animate-on-scroll fade-up">
    <h1>{{ page.title }}</h1>
  </div>
  <div class="page-content__body rte animate-on-scroll fade-up">
    {{ page.content }}
  </div>
</div>
<style>
  .page-content { padding-block: 3.5rem 5rem; max-width: 800px; background: var(--color-background, #FAFAF9); }
  .page-content__header { margin-bottom: 2.5rem; }
  .page-content h1 { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 700; letter-spacing: -0.01em; }
  .page-content__body { line-height: 1.8; color: var(--color-primary, #111111); }
</style>
{% schema %}
{ "name": "Page Content", "tag": "section", "class": "section-page-content" }
{% endschema %}
