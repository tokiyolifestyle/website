<div class="page-content page-width">
  {% render 'breadcrumbs' %}
  <div class="page-content__header animate-on-scroll fade-up">
    <h1>{{ page.title }}</h1>
  </div>
  <div class="page-content__body rte animate-on-scroll fade-up">
    {{ page.content }}
  </div>
</div>
<style>
  .page-content { padding-block:2.5rem var(--spacing-sections,64px); max-width:820px; }
  .page-content__header { margin-bottom:2rem; }
  .page-content h1 { font-size:clamp(1.75rem,3vw,2.5rem); }
</style>
{% schema %}
{ "name": "Page Content", "tag": "section", "class": "section-page-content" }
{% endschema %}
