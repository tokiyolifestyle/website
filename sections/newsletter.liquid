<section class="newsletter-section section-newsletter">
  <div class="page-width">
    <div class="newsletter-section__inner animate-on-scroll scale-in">
      <div class="newsletter-section__text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="text-eyebrow" style="color:var(--color-accent);">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2>{{ section.settings.title }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="newsletter-section__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      {%- form 'customer', id: 'SectionNewsletterForm' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-section__form">
          <label for="SectionNewsletterEmail" class="visually-hidden">{{ 'general.newsletter_form.newsletter_email' | t }}</label>
          <input
            type="email"
            name="contact[email]"
            id="SectionNewsletterEmail"
            placeholder="{{ section.settings.placeholder }}"
            required>
          <button type="submit" class="button button--solid">{{ section.settings.button_label }}</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="newsletter-section__success">{{ section.settings.success_message }}</p>
        {%- endif -%}
        {%- if section.settings.disclaimer != blank -%}
          <p class="newsletter-section__disclaimer">{{ section.settings.disclaimer }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  .newsletter-section {
    padding: 5rem 0;
    background: var(--color-surface, #141414);
    border-top: 1px solid var(--color-border, rgba(255,255,255,0.06));
    border-bottom: 1px solid var(--color-border, rgba(255,255,255,0.06));
  }
  .newsletter-section__inner { text-align:center; max-width:560px; margin:0 auto; }
  .newsletter-section__inner h2 { font-size:clamp(1.5rem,3vw,2.25rem); margin-bottom:.5rem; color:#fff; }
  .newsletter-section__subtitle { color:rgba(255,255,255,0.4); margin-bottom:2rem; }
  .newsletter-section__form { display:flex; gap:0; margin-bottom:1rem; }
  .newsletter-section__form input {
    flex:1; padding:.9rem 1.25rem;
    border:1px solid var(--color-border, rgba(255,255,255,0.1));
    background:rgba(255,255,255,0.04); color:#fff;
    font-size:0.875rem;
  }
  .newsletter-section__form input::placeholder { color:rgba(255,255,255,0.25); }
  .newsletter-section__form input:focus { outline:none; border-color:var(--color-accent,#C9A86A); }
  .newsletter-section__success { color:var(--color-accent,#C9A86A); font-weight:600; }
  .newsletter-section__disclaimer { font-size:.6875rem; margin-top:.5rem; color:rgba(255,255,255,0.2); }
  @media(max-width:600px){ .newsletter-section__form { flex-direction:column; } }
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay Connected" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Get Early Access to New Drops" },
    { "type": "text", "id": "subtitle", "label": "Subtext", "default": "Subscribe and get 10% off your first order. No spam, just good style." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "You're in! Check your inbox for your discount code." },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer text", "default": "By subscribing you agree to our Privacy Policy." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
