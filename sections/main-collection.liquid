{% render 'breadcrumbs' %}

<div class="collection-page page-width">
  <div class="collection-page__header">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="collection-page__desc">{{ collection.description }}</p>
    {%- endif -%}
  </div>

  <div class="collection-page__toolbar">
    <div class="collection-toolbar__left">
      <button class="collection-toolbar__filter-toggle" data-filter-toggle aria-expanded="false" aria-controls="CollectionFilters">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="12" y1="18" x2="12" y2="18"/></svg>
        Filter
        {%- if results.active_filters.size > 0 -%}
          <span class="filter-count-badge">{{ results.active_filters.size }}</span>
        {%- endif -%}
      </button>
      <span class="collection-toolbar__count">{{ 'sections.collection.products_count' | t: count: collection.products_count }}</span>
    </div>

    <div class="collection-toolbar__right">
      <div class="collection-toolbar__view">
        <button class="collection-toolbar__view-btn is-active" data-view="grid" aria-label="{{ 'sections.collection.view_as_grid' | t }}">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="0" width="7" height="7"/><rect x="9" y="0" width="7" height="7"/><rect x="0" y="9" width="7" height="7"/><rect x="9" y="9" width="7" height="7"/></svg>
        </button>
        <button class="collection-toolbar__view-btn" data-view="list" aria-label="{{ 'sections.collection.view_as_list' | t }}">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="0" width="16" height="3"/><rect x="0" y="6" width="16" height="3"/><rect x="0" y="12" width="16" height="3"/></svg>
        </button>
      </div>

      {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
      <div class="collection-toolbar__sort">
        <label for="SortBy" class="visually-hidden">{{ 'sections.collection.sort_by' | t }}</label>
        <select id="SortBy" name="sort_by" data-sort-by>
          {%- assign sort_options = 'manual,best-selling,title-ascending,title-descending,price-ascending,price-descending,created-descending,created-ascending' | split: ',' -%}
          {%- assign sort_labels = 'Featured,Best selling,A-Z,Z-A,Price low to high,Price high to low,Newest,Oldest' | split: ',' -%}
          {%- for option in sort_options -%}
            <option value="{{ option }}" {% if sort_by == option %}selected{% endif %}>{{ sort_labels[forloop.index0] }}</option>
          {%- endfor -%}
        </select>
      </div>
    </div>
  </div>

  <div class="collection-page__body">
    {%- comment -%} Filters sidebar {%- endcomment -%}
    <aside class="collection-filters" id="CollectionFilters" data-filters aria-hidden="true" style="transform: translateX(-100%); visibility: hidden;">
      <div class="collection-filters__header">
        <h2>{{ 'sections.collection.filter_by' | t }}</h2>
        <button class="collection-filters__close" data-filter-close aria-label="{{ 'accessibility.close' | t }}">{% render 'icon-close' %}</button>
      </div>

      {%- if results.active_filters.size > 0 -%}
        <div class="collection-filters__active">
          <h3>Active filters</h3>
          <ul>
            {%- for filter in results.active_filters -%}
              <li><a href="{{ filter.url_to_remove }}" class="active-filter-remove">✕ {{ filter.label }}: {{ filter.value }}</a></li>
            {%- endfor -%}
          </ul>
          <a href="{{ collection.url }}" class="button button--small button--outline">{{ 'sections.collection.clear_all' | t }}</a>
        </div>
      {%- endif -%}

      {%- assign decoded_query = canonical_url | split: '?' | last | replace: '%20', ' ' | replace: '%3A', ':' | replace: '%2F', '/' | replace: '%2C', ',' | replace: '+', ' ' -%}

      {%- assign gender_options = "Men,Women" | split: "," -%}
      {%- assign style_options = "Oversized,Regular" | split: "," -%}
      {%- assign size_options = "XS,S,M,L,XL,XXL" | split: "," -%}
      {%- assign color_options = "Black,White,Beige,Pista,Airforce,Peach,Lavender,Mustard,Onion Pink" | split: "," -%}
      {%- assign fabric_options = "100% Cotton,French Terry,Heavyweight Cotton" | split: "," -%}
      {%- assign brand_options = "Tokiyo Lifestyle,Tokiyo Originals" | split: "," -%}

      {%- assign in_stock_checked = '' -%}
      {%- if decoded_query contains 'filter.v.availability=1' -%}{%- assign in_stock_checked = 'checked' -%}{%- endif -%}

      {%- assign out_stock_checked = '' -%}
      {%- if decoded_query contains 'filter.v.availability=0' -%}{%- assign out_stock_checked = 'checked' -%}{%- endif -%}

      {%- assign price_gte = '' -%}
      {%- if decoded_query contains 'filter.v.price.gte=' -%}
        {%- assign price_gte = decoded_query | split: 'filter.v.price.gte=' | last | split: '&' | first -%}
      {%- endif -%}

      {%- assign price_lte = '' -%}
      {%- if decoded_query contains 'filter.v.price.lte=' -%}
        {%- assign price_lte = decoded_query | split: 'filter.v.price.lte=' | last | split: '&' | first -%}
      {%- endif -%}

      {%- comment -%} 0.1 Gender Filter {%- endcomment -%}
      <div class="filter-group" data-filter-group>
        <button class="filter-group__title" data-accordion-trigger data-accordion-group="filters" aria-expanded="true" aria-controls="Filter-Gender">
          Gender
          {% render 'icon-chevron-down' %}
        </button>
        <div class="filter-group__options" id="Filter-Gender">
          <ul class="filter-list">
            {%- for gender in gender_options -%}
              {%- assign is_checked = '' -%}
              {%- assign gender_query = 'filter.p.tag=' | append: gender -%}
              {%- if decoded_query contains gender_query -%}{%- assign is_checked = 'checked' -%}{%- endif -%}
              <li class="filter-list__item">
                <label class="filter-checkbox">
                  <input type="checkbox" name="filter.p.tag" value="{{ gender }}" {{ is_checked }} data-filter-input>
                  <span>{% if gender == 'Men' %}Men's{% else %}Women's{% endif %}</span>
                </label>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>

      {%- comment -%} 0.2 Style/Fit Filter {%- endcomment -%}
      <div class="filter-group" data-filter-group>
        <button class="filter-group__title" data-accordion-trigger data-accordion-group="filters" aria-expanded="true" aria-controls="Filter-Style">
          Fit / Silhouette
          {% render 'icon-chevron-down' %}
        </button>
        <div class="filter-group__options" id="Filter-Style">
          <ul class="filter-list">
            {%- for style in style_options -%}
              {%- assign is_checked = '' -%}
              {%- assign style_query = 'filter.p.tag=' | append: style -%}
              {%- if decoded_query contains style_query -%}{%- assign is_checked = 'checked' -%}{%- endif -%}
              <li class="filter-list__item">
                <label class="filter-checkbox">
                  <input type="checkbox" name="filter.p.tag" value="{{ style }}" {{ is_checked }} data-filter-input>
                  <span>{{ style }}</span>
                </label>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>

      {%- comment -%} 1. Availability Filter {%- endcomment -%}
      <div class="filter-group" data-filter-group>
        <button class="filter-group__title" data-accordion-trigger data-accordion-group="filters" aria-expanded="true" aria-controls="Filter-Availability">
          Availability
          {% render 'icon-chevron-down' %}
        </button>
        <div class="filter-group__options" id="Filter-Availability">
          <ul class="filter-list">
            <li class="filter-list__item">
              <label class="filter-checkbox">
                <input type="checkbox" name="filter.v.availability" value="1" {{ in_stock_checked }} data-filter-input>
                <span>In Stock</span>
              </label>
            </li>
            <li class="filter-list__item">
              <label class="filter-checkbox">
                <input type="checkbox" name="filter.v.availability" value="0" {{ out_stock_checked }} data-filter-input>
                <span>Out of Stock</span>
              </label>
            </li>
          </ul>
        </div>
      </div>

      {%- comment -%} 2. Price Filter {%- endcomment -%}
      <div class="filter-group" data-filter-group>
        <button class="filter-group__title" data-accordion-trigger data-accordion-group="filters" aria-expanded="true" aria-controls="Filter-Price">
          Price (₹)
          {% render 'icon-chevron-down' %}
        </button>
        <div class="filter-group__options" id="Filter-Price">
          <div class="filter-price-range">
            <div class="filter-price-inputs">
              <div class="filter-price-input">
                <label for="Filter-Price-GTE">Min ₹</label>
                <input type="number" id="Filter-Price-GTE" name="filter.v.price.gte" min="0" placeholder="0" value="{{ price_gte }}">
              </div>
              <div class="filter-price-input">
                <label for="Filter-Price-LTE">Max ₹</label>
                <input type="number" id="Filter-Price-LTE" name="filter.v.price.lte" min="0" placeholder="5000" value="{{ price_lte }}">
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} 3. Size Filter {%- endcomment -%}
      <div class="filter-group" data-filter-group>
        <button class="filter-group__title" data-accordion-trigger data-accordion-group="filters" aria-expanded="true" aria-controls="Filter-Size">
          Size
          {% render 'icon-chevron-down' %}
        </button>
        <div class="filter-group__options" id="Filter-Size">
          <ul class="filter-list">
            {%- for size in size_options -%}
              {%- assign is_checked = '' -%}
              {%- assign size_query = 'filter.v.option.size=' | append: size -%}
              {%- if decoded_query contains size_query -%}{%- assign is_checked = 'checked' -%}{%- endif -%}
              <li class="filter-list__item">
                <label class="filter-checkbox">
                  <input type="checkbox" name="filter.v.option.size" value="{{ size }}" {{ is_checked }} data-filter-input>
                  <span>{{ size }}</span>
                </label>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>

      {%- comment -%} 4. Color Filter {%- endcomment -%}
      <div class="filter-group" data-filter-group>
        <button class="filter-group__title" data-accordion-trigger data-accordion-group="filters" aria-expanded="true" aria-controls="Filter-Color">
          Color
          {% render 'icon-chevron-down' %}
        </button>
        <div class="filter-group__options" id="Filter-Color">
          <ul class="filter-list">
            {%- for color in color_options -%}
              {%- assign is_checked = '' -%}
              {%- assign color_query = 'filter.v.option.color=' | append: color -%}
              {%- if decoded_query contains color_query -%}{%- assign is_checked = 'checked' -%}{%- endif -%}
              
              {%- comment -%} Map color names to Hex colors for swatches {%- endcomment -%}
              {%- assign hex_color = '#111' -%}
              {%- if color == 'White' -%}{%- assign hex_color = '#FFFFFF' -%}
              {%- elsif color == 'Beige' -%}{%- assign hex_color = '#E4D5B7' -%}
              {%- elsif color == 'Pista' -%}{%- assign hex_color = '#C1F8C2' -%}
              {%- elsif color == 'Airforce' -%}{%- assign hex_color = '#5F8A96' -%}
              {%- elsif color == 'Peach' -%}{%- assign hex_color = '#FFE5B4' -%}
              {%- elsif color == 'Lavender' -%}{%- assign hex_color = '#E6E6FA' -%}
              {%- elsif color == 'Mustard' -%}{%- assign hex_color = '#E1AD01' -%}
              {%- elsif color == 'Onion Pink' -%}{%- assign hex_color = '#D1A3A4' -%}
              {%- elsif color == 'Black' -%}{%- assign hex_color = '#111111' -%}
              {%- endif -%}

              <li class="filter-list__item">
                <label class="filter-checkbox">
                  <input type="checkbox" name="filter.v.option.color" value="{{ color }}" {{ is_checked }} data-filter-input>
                  <span class="swatch swatch--sm" style="background-color:{{ hex_color }}; border: 1px solid rgba(0,0,0,0.12);"></span>
                  <span>{{ color }}</span>
                </label>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>

      {%- comment -%} 5. Fabric Filter {%- endcomment -%}
      <div class="filter-group" data-filter-group>
        <button class="filter-group__title" data-accordion-trigger data-accordion-group="filters" aria-expanded="true" aria-controls="Filter-Fabric">
          Fabric / Material
          {% render 'icon-chevron-down' %}
        </button>
        <div class="filter-group__options" id="Filter-Fabric">
          <ul class="filter-list">
            {%- for fabric in fabric_options -%}
              {%- assign is_checked = '' -%}
              {%- assign fabric_query = 'filter.p.tag=' | append: fabric -%}
              {%- if decoded_query contains fabric_query -%}{%- assign is_checked = 'checked' -%}{%- endif -%}
              <li class="filter-list__item">
                <label class="filter-checkbox">
                  <input type="checkbox" name="filter.p.tag" value="{{ fabric }}" {{ is_checked }} data-filter-input>
                  <span>{{ fabric }}</span>
                </label>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>

      {%- comment -%} 6. Brand Filter {%- endcomment -%}
      <div class="filter-group" data-filter-group>
        <button class="filter-group__title" data-accordion-trigger data-accordion-group="filters" aria-expanded="true" aria-controls="Filter-Brand">
          Brand
          {% render 'icon-chevron-down' %}
        </button>
        <div class="filter-group__options" id="Filter-Brand">
          <ul class="filter-list">
            {%- for brand in brand_options -%}
              {%- assign is_checked = '' -%}
              {%- assign brand_query = 'filter.p.vendor=' | append: brand -%}
              {%- if decoded_query contains brand_query -%}{%- assign is_checked = 'checked' -%}{%- endif -%}
              <li class="filter-list__item">
                <label class="filter-checkbox">
                  <input type="checkbox" name="filter.p.vendor" value="{{ brand }}" {{ is_checked }} data-filter-input>
                  <span>{{ brand }}</span>
                </label>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>

      <div class="collection-filters__footer">
        <button class="button button--solid button--full" data-filter-apply>{{ 'sections.collection.apply' | t }}</button>
      </div>
    </aside>

    {%- comment -%} Product grid {%- endcomment -%}
    <div class="collection-grid-wrap">
      {%- paginate collection.products by section.settings.products_per_page -%}
        {%- if collection.products.size > 0 -%}
          <div id="ProductGrid" class="product-grid product-grid--{{ section.settings.columns }} stagger-children" data-product-grid>
            {%- for product in collection.products -%}
              {% render 'product-card', product: product, lazy: true %}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate %}
          {%- endif -%}
        {%- else -%}
          <div class="collection-empty">
            <p>{{ 'sections.collection.no_products' | t }}</p>
            {%- if results.active_filters.size > 0 -%}
              <p>{{ 'sections.collection.use_fewer_filters' | t }}</p>
              <a href="{{ collection.url }}" class="button button--outline">{{ 'sections.collection.clear_all' | t }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>
  <div class="collection-filters__overlay" data-filter-overlay></div>
</div>

<style>
  .collection-page { padding-block: 2.5rem 4rem; background: var(--color-background, #FFFFFF); }
  .collection-page__header { margin-bottom: 1.5rem; }
  .collection-page__desc { color: var(--color-text-muted, #767674); max-width: 640px; margin-top: .5rem; }
  .collection-page__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-top: 1px solid var(--color-border, rgba(0,0,0,0.06));
    border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.06));
    margin-bottom: 2rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .collection-toolbar__left, .collection-toolbar__right { display: flex; align-items: center; gap: 1.5rem; }
  .collection-toolbar__filter-toggle {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-weight: 600;
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary, #111111);
  }
  .filter-count-badge {
    background: var(--color-accent, #ff0000);
    color: #FFFFFF;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    font-size: .65rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .collection-toolbar__count { font-size: .8125rem; color: var(--color-text-muted, #767674); }
  .collection-toolbar__view { display: flex; gap: .5rem; }
  .collection-toolbar__view-btn { padding: .35rem; color: #CCCCCC; transition: color .2s; }
  .collection-toolbar__view-btn.is-active { color: var(--color-primary, #111111); }
  .collection-toolbar__sort select {
    border: none;
    border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.12));
    background: transparent;
    border-radius: 0;
    padding: 0.5rem 1.5rem 0.5rem 0.5rem;
    font-size: .75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    color: var(--color-primary, #111111);
  }
  .collection-page__body { display: grid; grid-template-columns: 260px 1fr; gap: 3rem; align-items: start; }
  @media(max-width: 989px){ .collection-page__body { grid-template-columns: 1fr; } }

  /* Filters */
  .collection-filters {
    background: transparent;
    border-radius: 0;
    border: none;
    border-right: 1px solid var(--color-border, rgba(0,0,0,0.06));
    padding-right: 2rem;
  }
  @media(min-width: 990px) {
    .collection-filters {
      transform: none !important;
      visibility: visible !important;
    }
  }
  @media(max-width: 989px){
    .collection-filters {
      position: fixed;
      top: 0;
      left: 0;
      height: 100dvh;
      max-height: 100vh;
      width: min(320px, 100vw);
      z-index: 60;
      transform: translateX(-100%);
      transition: transform .3s cubic-bezier(0.25, 0.46, 0.45, 0.94), visibility .3s;
      visibility: hidden;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-y: contain;
      border-radius: 0;
      background: #FFFFFF;
      padding: 1.5rem;
      padding-bottom: 6rem;
      border-right: none;
      box-shadow: 10px 0 30px rgba(0,0,0,0.05);
    }
    .collection-filters.is-open { transform: translateX(0) !important; visibility: visible !important; }
    .collection-filters__overlay { position: fixed; inset: 0; background: rgba(0,0,0,.3); z-index: 55; opacity: 0; visibility: hidden; transition: opacity .3s; backdrop-filter: blur(2px); }
    .collection-filters__overlay.is-open { opacity: 1; visibility: visible; }
  }
  .collection-filters__header { display: flex; justify-content: space-between; align-items: center; padding: 0 0 1rem; border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.06)); }
  .collection-filters__header h2 { font-size: .875rem; margin: 0; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; }
  .collection-filters__close { display: none; }
  @media(max-width: 989px){ .collection-filters__close { display: flex; width: 32px; height: 32px; align-items: center; justify-content: center; } }
  .collection-filters__active { padding: 1rem 0; border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.06)); }
  .collection-filters__active h3 { font-size: .75rem; margin-bottom: .5rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted, #767674); }
  .active-filter-remove { font-size: .75rem; color: var(--color-error, #C62828); display: block; margin-bottom: .3rem; text-decoration: underline; }
  .filter-group { border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.06)); }
  .filter-group__title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 1.25rem 0;
    font-weight: 700;
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary, #111111);
  }
  .filter-group__title[aria-expanded="true"] svg { transform: rotate(180deg); }
  .filter-group__title svg { transition: transform .2s; width: 12px; height: 12px; }
  .filter-group__options { padding: 0 0 1.25rem; }
  .filter-list { display: flex; flex-direction: column; gap: .65rem; }
  .filter-checkbox { display: flex; align-items: center; gap: .65rem; cursor: pointer; font-size: .875rem; color: var(--color-primary, #111111); }
  .filter-checkbox input {
    width: 15px;
    height: 15px;
    border: 1px solid var(--color-border, rgba(0,0,0,0.15));
    border-radius: 0;
    accent-color: var(--color-accent, #ff0000);
  }
  .filter-count { color: var(--color-text-muted, #767674); font-size: .75rem; margin-left: auto; }
  .swatch--sm { width: 14px; height: 14px; border-radius: 50%; border: 1px solid rgba(0,0,0,.1); display: inline-block; }
  .filter-price-inputs { display: flex; gap: .75rem; }
  .filter-price-input { display: flex; flex-direction: column; gap: .35rem; font-size: .75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted, #767674); }
  .filter-price-input input {
    border: none;
    border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.15));
    background: transparent;
    padding: .4rem 0;
    width: 100%;
    border-radius: 0;
  }
  .collection-filters__footer { padding: 1.25rem 0 0; }

  /* Grid / list */
  #ProductGrid.is-list { grid-template-columns:1fr !important; }
  #ProductGrid.is-list .product-card { display:flex; flex-direction:row; }
  #ProductGrid.is-list .product-card__media { width:180px; flex-shrink:0; aspect-ratio:auto; height:220px; }
  #ProductGrid.is-list .product-card__info { flex:1; padding:1.25rem; }

  .collection-empty { text-align:center; padding:4rem 0; color:#888; }
  .collection-empty .button { margin-top:1rem; }
</style>

<script>
  (function(){
    /* Sort by */
    const sortSelect = document.querySelector('[data-sort-by]');
    sortSelect && sortSelect.addEventListener('change', () => {
      const url = new URL(window.location);
      url.searchParams.set('sort_by', sortSelect.value);
      window.location = url.toString();
    });

    /* Grid / list toggle */
    document.querySelectorAll('[data-view]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-view]').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        const grid = document.getElementById('ProductGrid');
        if (grid) grid.classList.toggle('is-list', btn.dataset.view === 'list');
      });
    });

    /* Filter toggle (mobile) */
    const filterToggle = document.querySelector('[data-filter-toggle]');
    const filters      = document.getElementById('CollectionFilters');
    const filterOverlay = document.querySelector('[data-filter-overlay]');
    function openFilters() { filters?.classList.add('is-open'); filterOverlay?.classList.add('is-open'); document.body.style.overflow='hidden'; }
    function closeFilters() { filters?.classList.remove('is-open'); filterOverlay?.classList.remove('is-open'); document.body.style.overflow=''; }
    filterToggle && filterToggle.addEventListener('click', openFilters);
    document.querySelector('[data-filter-close]')?.addEventListener('click', closeFilters);
    filterOverlay && filterOverlay.addEventListener('click', closeFilters);

    /* Apply filters */
    document.querySelector('[data-filter-apply]')?.addEventListener('click', () => {
      const url = new URL(window.location.pathname, window.location.origin);
      const currentUrl = new URL(window.location);
      if (currentUrl.searchParams.has('sort_by')) {
        url.searchParams.set('sort_by', currentUrl.searchParams.get('sort_by'));
      }
      document.querySelectorAll('[data-filter-input]').forEach(input => {
        if (input.type === 'checkbox') {
          if (input.checked) {
            url.searchParams.append(input.name, input.value);
          }
        }
      });
      document.querySelectorAll('.filter-price-inputs input').forEach(input => {
        if (input.value && input.value !== '') {
          url.searchParams.set(input.name, input.value);
        }
      });
      window.location = url.toString();
    });
  })();
</script>

