{%- comment -%} Featured Reviews — Dark Glass Cards {%- endcomment -%}

<section class="reviews section-reviews" style="background:{{ section.settings.background | default: '#0A0A0A' }};">
  <div class="page-width">
    <div class="section-header-block animate-on-scroll fade-up">
      <p class="text-eyebrow">{{ section.settings.eyebrow | default: 'Reviews' }}</p>
      <h2>{{ section.settings.title | default: 'What Our Customers Say' }}</h2>
    </div>

    <div class="reviews__grid stagger-children">
      {%- for block in section.blocks -%}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars">
            {%- assign rating = block.settings.rating | default: 5 -%}
            {%- for i in (1..5) -%}
              {%- if i <= rating -%}
                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M10 1l2.39 6.56H19l-5.3 4.04 1.97 6.56L10 14.24l-5.67 3.92 1.97-6.56L1 7.56h6.61z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1" width="14" height="14"><path d="M10 1l2.39 6.56H19l-5.3 4.04 1.97 6.56L10 14.24l-5.67 3.92 1.97-6.56L1 7.56h6.61z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <p class="review-card__text">"{{ block.settings.text }}"</p>
          <div class="review-card__author">
            <div class="review-card__avatar">{{ block.settings.author | slice: 0 }}</div>
            <div>
              <strong>{{ block.settings.author }}</strong>
              {%- if block.settings.verified -%}
                <span class="review-card__verified">✓ Verified Buyer</span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .reviews { padding: 1.5rem 0; background: var(--color-background, #FAFAF9); }
  .reviews__grid {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 1rem;
  }
  .reviews__grid::-webkit-scrollbar {
    display: none;
  }
  
  .review-card {
    background: var(--color-surface, #FFFFFF);
    border: 1px solid var(--color-border, rgba(0,0,0,0.06));
    padding: 2rem;
    transition: border-color .3s ease, box-shadow .3s ease;
    flex: 0 0 85%;
    scroll-snap-align: start;
  }
  @media(min-width: 750px) {
    .review-card {
      flex: 0 0 calc(33.333% - 1rem);
    }
    .reviews__grid {
      justify-content: center;
      overflow: visible;
      padding-bottom: 0;
    }
  }
  .review-card:hover {
    border-color: var(--color-accent, #B89047);
    box-shadow: 0 8px 24px rgba(0,0,0,0.03);
  }
  .review-card__stars { display:flex; gap:2px; color:var(--color-accent, #C5A880); margin-bottom:1.25rem; }
  .review-card__text {
    font-size:0.9375rem; line-height:1.8;
    color: rgba(17, 17, 17, 0.75); margin-bottom:1.5rem;
    font-style:italic;
  }
  .review-card__author { display:flex; align-items:center; gap:0.75rem; }
  .review-card__avatar {
    width:36px; height:36px;
    background: var(--color-accent, #C5A880); color: var(--color-primary, #0C0C0E);
    display:flex; align-items:center; justify-content:center;
    font-weight:800; font-size:0.875rem;
    text-transform:uppercase;
  }
  .review-card__author strong { color: var(--color-primary, #111111); font-size:0.8125rem; display:block; }
  .review-card__verified { font-size:0.6875rem; color:var(--color-accent, #C5A880); display:block; margin-top:2px; }
</style>

{% schema %}
{
  "name": "Featured Reviews",
  "tag": "section",
  "class": "section-reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "title", "label": "Heading", "default": "What Our Customers Say" },
    { "type": "color", "id": "background", "label": "Background", "default": "#FAFAF9" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "author", "label": "Author name", "default": "Customer" },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "Amazing quality! The fabric feels premium and the fit is perfect." },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true }
      ]
    }
  ],
  "presets": [{
    "name": "Featured Reviews",
    "blocks": [
      { "type": "review", "settings": { "author": "Arjun M.", "text": "The oversized tee is hands down the best I've owned. Premium cotton, perfect drape, and the packaging was elite. Tokiyo gets it!", "rating": 5, "verified": true } },
      { "type": "review", "settings": { "author": "Priya S.", "text": "Obsessed with the cargo pants! The quality is unreal for the price. Already ordered two more pieces. Definitely my new go-to brand.", "rating": 5, "verified": true } },
      { "type": "review", "settings": { "author": "Rahul K.", "text": "Fast shipping, beautiful packaging, and the hoodie fits like a dream. This brand is going places. Highly recommend!", "rating": 5, "verified": true } }
    ]
  }]
}
{% endschema %}
