<section class="featured-reviews section-featured-reviews">
  <div class="page-width">
    <div class="section-header-block animate-on-scroll fade-up">
      {%- if section.settings.eyebrow != blank -%}<p class="text-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2>{{ section.settings.title }}</h2>
      {%- if section.settings.aggregate_rating != blank -%}
        <div class="reviews-aggregate">
          <div class="reviews-stars" aria-label="{{ section.settings.aggregate_rating }} out of 5 stars">
            {%- assign full_stars = section.settings.aggregate_rating | floor -%}
            {%- for i in (1..5) -%}
              <span class="star {% if i <= full_stars %}star--filled{% endif %}">{% assign filled = false %}{% if i <= full_stars %}{% assign filled = true %}{% endif %}{% render 'icon-star', filled: filled %}</span>
            {%- endfor -%}
          </div>
          <strong>{{ section.settings.aggregate_rating }}</strong>
          <span class="reviews-aggregate__count">({{ section.settings.total_reviews }} reviews)</span>
        </div>
      {%- endif -%}
    </div>

    <div class="reviews-grid stagger-children">
      {%- for block in section.blocks -%}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- assign r = block.settings.rating | plus: 0 -%}
            {%- for i in (1..5) -%}
              {%- assign filled = false -%}
              {%- if i <= r -%}{%- assign filled = true -%}{%- endif -%}
              {% render 'icon-star', filled: filled %}
            {%- endfor -%}
          </div>
          {%- if block.settings.review_text != blank -%}
            <p class="review-card__text">{{ block.settings.review_text }}</p>
          {%- endif -%}
          <div class="review-card__author">
            {%- if block.settings.author_image != blank -%}
              {{ block.settings.author_image | image_url: width: 80 | image_tag: loading: 'lazy', class: 'review-card__avatar', alt: block.settings.author_name | escape }}
            {%- else -%}
              <div class="review-card__avatar review-card__avatar--initials" aria-hidden="true">{{ block.settings.author_name | slice: 0, 1 | upcase }}</div>
            {%- endif -%}
            <div>
              <strong class="review-card__name">{{ block.settings.author_name }}</strong>
              {%- if block.settings.author_location != blank -%}<span class="review-card__location">{{ block.settings.author_location }}</span>{%- endif -%}
              {%- if block.settings.verified -%}<span class="review-card__verified">✓ Verified purchase</span>{%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .featured-reviews { background:var(--color-background,#f9f9f9); }
  .reviews-aggregate { display:flex; align-items:center; gap:.75rem; justify-content:center; margin-top:.75rem; }
  .reviews-stars, .review-card__stars { display:flex; gap:2px; color:var(--color-accent,#C9A86A); }
  .star--filled svg { fill:currentColor; }
  .reviews-aggregate__count { color:#888; font-size:.875rem; }
  .reviews-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
  @media(max-width:989px){ .reviews-grid { grid-template-columns:repeat(2,1fr); } }
  @media(max-width:600px){ .reviews-grid { grid-template-columns:1fr; } }
  .review-card { background:#fff; border-radius:var(--card-radius,12px); padding:1.75rem; box-shadow:0 4px 18px rgba(17,17,17,.05); }
  .review-card__stars { margin-bottom:1rem; }
  .review-card__text { color:#444; font-size:.9375rem; line-height:1.7; margin-bottom:1.25rem; }
  .review-card__author { display:flex; gap:.75rem; align-items:center; }
  .review-card__avatar { width:42px; height:42px; border-radius:50%; object-fit:cover; }
  .review-card__avatar--initials { background:var(--color-accent,#C9A86A); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:1rem; }
  .review-card__name { display:block; font-size:.9rem; }
  .review-card__location,.review-card__verified { display:block; font-size:.75rem; color:#888; }
  .review-card__verified { color:var(--color-success,#3BB273); }
</style>

{% schema %}
{
  "name": "Featured Reviews",
  "tag": "section",
  "class": "section-featured-reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer Love" },
    { "type": "text", "id": "title", "label": "Title", "default": "What Our Customers Say" },
    { "type": "text", "id": "aggregate_rating", "label": "Aggregate rating (e.g. 4.8)", "default": "4.8" },
    { "type": "text", "id": "total_reviews", "label": "Total reviews count", "default": "2,400+" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "textarea", "id": "review_text", "label": "Review text", "default": "Absolutely love the quality. The fabric is so soft and the fit is perfect. Will definitely be ordering more!" },
        { "type": "image_picker", "id": "author_image", "label": "Author photo" },
        { "type": "text", "id": "author_name", "label": "Author name", "default": "Priya S." },
        { "type": "text", "id": "author_location", "label": "Author location", "default": "Mumbai, India" },
        { "type": "checkbox", "id": "verified", "label": "Verified purchase", "default": true }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "review", "settings": { "rating": 5, "review_text": "The quality exceeded my expectations. The fabric is incredibly soft and the stitching is flawless.", "author_name": "Priya S.", "author_location": "Mumbai", "verified": true } },
      { "type": "review", "settings": { "rating": 5, "review_text": "Great fits, quick delivery, love the minimalist designs. My go-to brand for everyday wear.", "author_name": "Arjun M.", "author_location": "Bengaluru", "verified": true } },
      { "type": "review", "settings": { "rating": 5, "review_text": "Finally a brand that nails both quality and style. The oversized tee is my new favourite piece.", "author_name": "Sneha K.", "author_location": "Delhi", "verified": true } }
    ]
  },
  "presets": [{ "name": "Featured Reviews" }]
}
{% endschema %}
