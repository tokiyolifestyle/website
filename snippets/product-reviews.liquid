<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
  import { getFirestore, collection, addDoc, getDocs, query, where } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "AIzaSyCY-WiyDWBVfS64t_DAmh2NwukpXHkVzZQ",
    authDomain: "tokiyolifestyle-website.firebaseapp.com",
    projectId: "tokiyolifestyle-website",
    storageBucket: "tokiyolifestyle-website.firebasestorage.app",
    messagingSenderId: "270059975283",
    appId: "1:270059975283:web:d0fe2cf5169ff72ec1b006",
    measurementId: "G-XXH1MYLFKE"
  };

  const app = initializeApp(firebaseConfig);
  const db  = getFirestore(app);

  (function() {
    const section = document.getElementById('ProductReviews');
    if (!section) return;

    const productId = section.dataset.productId || 'default';
    const openBtn    = document.getElementById('OpenReviewFormBtn');
    const closeBtn   = document.getElementById('CloseReviewFormBtn');
    const formWrap   = document.getElementById('ReviewFormWrapper');
    const form       = document.getElementById('ProductReviewForm');
    const list       = document.getElementById('ProductReviewsList');
    const alertBox   = document.getElementById('ReviewSuccessAlert');
    const starPicker = document.getElementById('StarPicker');
    const ratingInput = document.getElementById('ReviewRatingInput');
    const backdrop   = document.getElementById('ReviewModalBackdrop');

    function openModal() {
      if (backdrop && backdrop.parentElement !== document.body) {
        document.body.appendChild(backdrop);
      }
      if (formWrap && formWrap.parentElement !== document.body) {
        document.body.appendChild(formWrap);
      }
      if (backdrop) backdrop.style.display = 'block';
      if (formWrap) formWrap.style.display = 'block';
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (formWrap) formWrap.style.display = 'none';
      if (backdrop) backdrop.style.display = 'none';
      document.body.style.overflow = '';
    }

    // Toggle Modal
    openBtn && openBtn.addEventListener('click', openModal);
    closeBtn && closeBtn.addEventListener('click', closeModal);
    backdrop && backdrop.addEventListener('click', closeModal);

    // Interactive Star Picker
    if (starPicker) {
      const stars = starPicker.querySelectorAll('.star-picker__star');
      stars.forEach(star => {
        star.addEventListener('click', () => {
          const val = parseInt(star.dataset.value, 10);
          ratingInput.value = val;
          stars.forEach((s, idx) => {
            s.classList.toggle('is-active', idx < val);
          });
        });
      });
    }

    // Image compression helper to keep Firestore document size small
    function compressImage(file) {
      return new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = new Image();
          img.onload = () => {
            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            const MAX_WIDTH = 600;
            const MAX_HEIGHT = 600;
            let width = img.width;
            let height = img.height;
            
            if (width > height) {
              if (width > MAX_WIDTH) {
                height *= MAX_WIDTH / width;
                width = MAX_WIDTH;
              }
            } else {
              if (height > MAX_HEIGHT) {
                width *= MAX_HEIGHT / height;
                height = MAX_HEIGHT;
              }
            }
            
            canvas.width = width;
            canvas.height = height;
            ctx.drawImage(img, 0, 0, width, height);
            resolve(canvas.toDataURL('image/jpeg', 0.7)); // Compress to JPEG with 70% quality
          };
          img.src = e.target.result;
        };
        reader.readAsDataURL(file);
      });
    }

    // Helper to render review card
    function createReviewCard(author, title, body, rating, date, images) {
      const item = document.createElement('div');
      item.className = 'review-item';
      item.style.borderColor = 'var(--color-accent, #ff0000)';

      let starsHtml = '';
      for (let i = 0; i < rating; i++) starsHtml += '★';

      let imagesHtml = '';
      if (images && images.length) {
        imagesHtml = `<div class="review-item__images">
          ${images.map(imgSrc => `<img src="${imgSrc}" class="review-item__img" alt="Review photo" onclick="if(window.openZoomModal)window.openZoomModal('${imgSrc}')">`).join('')}
        </div>`;
      }

      item.innerHTML = `
        <div class="review-item__header">
          <div class="review-item__author-wrap">
            <div class="review-item__avatar">${(author || 'U').charAt(0).toUpperCase()}</div>
            <div>
              <strong class="review-item__author">${author}</strong>
              <span class="review-item__verified">✓ Verified Buyer</span>
            </div>
          </div>
          <span class="review-item__date">${date}</span>
        </div>
        <div class="review-item__rating">${starsHtml} <span class="review-item__score-tag">${rating}.0</span></div>
        <h4 class="review-item__title">${title}</h4>
        <p class="review-item__body">${body}</p>
        ${imagesHtml}
      `;
      return item;
    }

    // Load Live Reviews from Firebase Firestore
    async function loadFirebaseReviews() {
      try {
        const q = query(
          collection(db, "reviews"),
          where("productId", "==", String(productId))
        );
        const querySnapshot = await getDocs(q);
        querySnapshot.forEach((doc) => {
          const data = doc.data();
          const card = createReviewCard(data.author, data.title, data.body, data.rating, data.date, data.images);
          list.insertBefore(card, list.firstChild);
        });
      } catch (err) {
        console.warn("Firestore fetch notice:", err);
      }
    }

    loadFirebaseReviews();

    // Form Submission to Firebase Firestore
    form && form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const author = document.getElementById('ReviewAuthor').value.trim();
      const title  = document.getElementById('ReviewTitle').value.trim();
      const body   = document.getElementById('ReviewBody').value.trim();
      const rating = parseInt(ratingInput.value || '5', 10);

      if (!author || !title || !body) return;

      const dateStr = new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

      // Handle photos compression & base64 conversion
      const fileInput = document.getElementById('ReviewImages');
      const files = fileInput ? fileInput.files : [];
      const imagePromises = [...files].slice(0, 3).map(file => compressImage(file));
      const imagesBase64 = await Promise.all(imagePromises);

      // Save to Firebase Firestore
      try {
        await addDoc(collection(db, "reviews"), {
          productId: String(productId),
          author,
          title,
          body,
          rating,
          images: imagesBase64,
          date: dateStr,
          timestamp: Date.now()
        });
      } catch (err) {
        console.error("Firestore save error:", err);
      }

      // Render live on UI immediately
      const card = createReviewCard(author, title, body, rating, dateStr, imagesBase64);
      list.insertBefore(card, list.firstChild);

      form.reset();
      closeModal();

      if (alertBox) {
        alertBox.style.display = 'block';
        setTimeout(() => { alertBox.style.display = 'none'; }, 4000);
      }
    });
  })();
</script>
