{%- comment -%}
  Product card snippet — Dark Premium
  Accepts: product, section (optional), lazy (optional, default: true), class_modifier
{%- endcomment -%}

{%- assign loading_attr = 'lazy' -%}
{%- if lazy == false -%}{%- assign loading_attr = 'eager' -%}{%- endif -%}
{%- assign card_class = 'product-card' -%}
{%- if class_modifier != blank -%}{%- assign card_class = card_class | append: ' ' | append: class_modifier -%}{%- endif -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign is_on_sale = false -%}
{%- if current_variant.compare_at_price > current_variant.price -%}{%- assign is_on_sale = true -%}{%- endif -%}
{%- assign save_percent = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}

<div class="{{ card_class }}" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title | escape }}">
    <div class="product-card__media{% if settings.card_image_ratio == 'square' %} is-square{% endif %}">

      {%- if product.featured_media -%}
        {{ product.featured_media | image_url: width: 600 | image_tag:
          loading: loading_attr,
          widths: '300, 400, 600',
          sizes: '(max-width:749px) 50vw, 25vw',
          class: 'product-card__image product-card__image--primary',
          alt: product.featured_media.alt | default: product.title | escape
        }}
        {%- if settings.show_secondary_image and product.images.size > 1 -%}
          {{ product.images[1] | image_url: width: 600 | image_tag:
            loading: 'lazy',
            widths: '300, 400, 600',
            sizes: '(max-width:749px) 50vw, 25vw',
            class: 'product-card__image product-card__image--secondary',
            alt: product.images[1].alt | default: product.title | escape
          }}
        {%- endif -%}
      {%- else -%}
        <div class="coming-soon-placeholder">
          <div class="coming-soon-placeholder__inner">
            <span class="coming-soon-placeholder__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </span>
            <span class="coming-soon-placeholder__text">Coming Soon</span>
          </div>
        </div>
      {%- endif -%}

      <div class="product-card__badges">
        {%- if product.available == false -%}
          <span class="badge badge--soldout">Sold Out</span>
        {%- elsif is_on_sale -%}
          <span class="badge badge--sale">-{{ save_percent }}%</span>
        {%- elsif product.tags contains 'new' or product.tags contains 'New Arrival' -%}
          <span class="badge badge--new">New</span>
        {%- endif -%}
      </div>

      {%- if settings.enable_wishlist -%}
        <button
          class="product-card__wishlist-btn"
          data-wishlist-toggle="{{ product.id }}"
          aria-label="Add to Wishlist"
          type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
      {%- endif -%}

      {%- if settings.show_quick_add and product.available -%}
        <div class="product-card__quick-add">
          {%- if product.has_only_default_variant -%}
            <button
              class="button button--solid button--full button--small"
              data-quick-add="{{ product.variants.first.id }}"
              type="button">
              Add to Cart
            </button>
          {%- else -%}
            <button
              class="button button--solid button--full button--small"
              data-quick-view="{{ product.handle }}"
              type="button">
              Select Options
            </button>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </a>

  <div class="product-card__info">
    {%- if settings.show_vendor -%}
      <p class="product-card__vendor">{{ product.vendor }}</p>
    {%- endif -%}
    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <div class="product-card__price">
      {%- if is_on_sale -%}
        <span class="price--sale">{{ current_variant.price | money }}</span>
        <span class="price--compare">{{ current_variant.compare_at_price | money }}</span>
      {%- else -%}
        <span>{{ current_variant.price | money }}</span>
      {%- endif -%}
    </div>

    {%- comment -%} Star Ratings {%- endcomment -%}
    <div class="product-card__rating">
      <div class="product-card__stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 20 20"><path d="M10 1l2.39 6.56H19l-5.3 4.04 1.97 6.56L10 14.24l-5.67 3.92 1.97-6.56L1 7.56h6.61z"/></svg>
        {%- endfor -%}
      </div>
      <span class="product-card__rating-count">4.8</span>
    </div>

    {%- assign color_option = product.options_by_name['Color'] -%}
    {%- if color_option != blank and color_option.values.size > 1 -%}
      <div class="product-card__swatches" aria-label="Colors">
        {%- for value in color_option.values limit: 4 -%}
          <span class="swatch" style="background-color:{{ value | handle | replace: '-', '' }};" title="{{ value }}"></span>
        {%- endfor -%}
        {%- if color_option.values.size > 4 -%}
          <span class="swatch--more">+{{ color_option.values.size | minus: 4 }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>
